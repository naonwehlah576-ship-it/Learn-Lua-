-- ========================================== --
--    FUNCTION: Check & Keep Auction Open    --
-- ========================================== --
local auctionCheckTask = nil

local function getAuctionGui()
    -- Cek apakah Auction GUI sudah ada di PlayerGui
    local auctionGui = LocalPlayer.PlayerGui:FindFirstChild("Auction")
    return auctionGui
end

local function isAuctionOpen()
    local auctionGui = getAuctionGui()
    if not auctionGui then
        return false -- GUI belum spawn
    end
    if not auctionGui:IsA("ScreenGui") then
        return false -- Bukan ScreenGui
    end
    return auctionGui.Enabled == true
end

local function startAuctionMonitor()
    -- Stop task lama kalau ada
    if auctionCheckTask then
        task.cancel(auctionCheckTask)
    end
    
    auctionCheckTask = task.spawn(function()
        print("[Monitor] Auction monitor dimulai - cek setiap 3 detik")
        
        while config.PriceMode or config.TimeMode do
            task.wait(3) -- Cek setiap 3 detik
            
            if config.PriceMode or config.TimeMode then
                local isOpen = isAuctionOpen()
                
                if not isOpen then
                    print("[AutoOpen] Auction UI tertutup, membuka kembali...")
                    openAuctionUI()
                    task.wait(0.5)
                else
                    print("[Monitor] Auction UI masih terbuka ✓")
                end
            end
        end
        print("[Monitor] Auction monitor dihentikan")
    end)
end

local function stopAuctionMonitor()
    if auctionCheckTask then
        task.cancel(auctionCheckTask)
        auctionCheckTask = nil
        print("[Monitor] Monitor dihentikan")
    end
end

