-- ========== FUNCTION: Create Section with Scrollable Items ==========
local function createSection(titleText, modeKey, limitKey, limitPlaceholder, itemsConfig)
    -- Header Frame (Toggle + Limit Input)
    local HeaderFrame = Instance.new("Frame")
    HeaderFrame.Size = UDim2.new(1, 0, 0, 30)
    HeaderFrame.BackgroundTransparency = 1
    HeaderFrame.Parent = MainFrame
    
    local MasterToggle = Instance.new("TextButton")
    MasterToggle.Size = UDim2.new(0.6, -5, 1, 0)
    MasterToggle.BackgroundColor3 = config[modeKey] and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
    MasterToggle.Text = titleText .. (config[modeKey] and " [ON]" or " [OFF]")
    MasterToggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    MasterToggle.Font = Enum.Font.GothamBold
    MasterToggle.TextSize = 14
    MasterToggle.Parent = HeaderFrame
    
    local LimitInput = Instance.new("TextBox")
    LimitInput.Size = UDim2.new(0.4, 0, 1, 0)
    LimitInput.Position = UDim2.new(0.6, 5, 0, 0)
    LimitInput.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    LimitInput.Text = tostring(config[limitKey])
    LimitInput.TextColor3 = Color3.fromRGB(255, 255, 255)
    LimitInput.Font = Enum.Font.Gotham
    LimitInput.TextSize = 14
    LimitInput.Parent = HeaderFrame
    
    MasterToggle.MouseButton1Click:Connect(function()
        config[modeKey] = not config[modeKey]
        MasterToggle.BackgroundColor3 = config[modeKey] and Color3.fromRGB(50, 200, 50) or Color3.fromRGB(200, 50, 50)
        MasterToggle.Text = titleText .. (config[modeKey] and " [ON]" or " [OFF]")
        SaveConfig()
        
        -- ========== AUTO OPEN AUCTION LOGIC ==========
        if config[modeKey] then
            print("[" .. titleText .. "] Mode ENABLED - Opening Auction UI...")
            openAuctionUI()
            task.wait(0.5)
            startAuctionMonitor() -- Mulai monitor
        else
            print("[" .. titleText .. "] Mode DISABLED")
            -- Cek apakah kedua mode OFF
            if not config.PriceMode and not config.TimeMode then
                stopAuctionMonitor() -- Stop monitor kalau kedua mode OFF
            end
        end
    end)
    
    LimitInput.FocusLost:Connect(function()
        local txt = LimitInput.Text:lower():gsub(" ", "")
        local mult = 1
        if txt:find("m") then mult = 1000000 txt = txt:gsub("m", "")
        elseif txt:find("k") then mult = 1000 txt = txt:gsub("k", "") end
        local val = tonumber(txt)
        if val then
            config[limitKey] = val * mult
            LimitInput.Text = tostring(val * mult)
            SaveConfig()
        else
            LimitInput.Text = tostring(config[limitKey])
        end
    end)
    
    -- Scrollable Items Container
    local ScrollContainer = Instance.new("Frame")
    ScrollContainer.Size = UDim2.new(1, 0, 0, 130)
    ScrollContainer.BackgroundColor3 = Color3.fromRGB(45, 45, 45)
    ScrollContainer.BorderSizePixel = 0
    ScrollContainer.Parent = MainFrame
    
    local ScrollingFrame = Instance.new("ScrollingFrame")
    ScrollingFrame.Size = UDim2.new(1, 0, 1, 0)
    ScrollingFrame.BackgroundTransparency = 1
    ScrollingFrame.ScrollBarThickness = 8
    ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, 0)
    ScrollingFrame.Parent = ScrollContainer
    
    local ListLayout = Instance.new("UIListLayout")
    ListLayout.SortOrder = Enum.SortOrder.LayoutOrder
    ListLayout.Padding = UDim.new(0, 2)
    ListLayout.Parent = ScrollingFrame
    
    local listPadding = Instance.new("UIPadding")
    listPadding.PaddingTop = UDim.new(0, 5)
    listPadding.PaddingLeft = UDim.new(0, 5)
    listPadding.PaddingRight = UDim.new(0, 5)
    listPadding.Parent = ScrollingFrame
    
    for _, item in ipairs(itemNames) do
        local key = item:lower()
        local ItemBtn = Instance.new("TextButton")
        ItemBtn.Size = UDim2.new(1, 0, 0, 25)
        ItemBtn.BackgroundColor3 = itemsConfig[key] and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(60, 60, 60)
        ItemBtn.Text = "  " .. item .. (itemsConfig[key] and " : ON" or " : OFF")
        ItemBtn.TextXAlignment = Enum.TextXAlignment.Left
        ItemBtn.TextColor3 = itemsConfig[key] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
        ItemBtn.Font = Enum.Font.Gotham
        ItemBtn.TextSize = 13
        ItemBtn.Parent = ScrollingFrame
        
        ItemBtn.MouseButton1Click:Connect(function()
            itemsConfig[key] = not itemsConfig[key]
            ItemBtn.BackgroundColor3 = itemsConfig[key] and Color3.fromRGB(50, 150, 50) or Color3.fromRGB(60, 60, 60)
            ItemBtn.Text = "  " .. item .. (itemsConfig[key] and " : ON" or " : OFF")
            ItemBtn.TextColor3 = itemsConfig[key] and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(200, 200, 200)
            SaveConfig()
        end)
    end
    
    -- Update CanvasSize berdasarkan jumlah items
    local function updateCanvasSize()
        local itemCount = #itemNames
        local itemHeight = 25
        local padding = 2
        local totalHeight = (itemCount * itemHeight) + ((itemCount - 1) * padding) + 10
        ScrollingFrame.CanvasSize = UDim2.new(0, 0, 0, totalHeight)
    end
    
    updateCanvasSize()
end

