--         FUNGSI PARSING                     --
-- ========================================== --
local function parseHarga(text)
    if not text or text == "" then return math.huge end
    local clean = string.gsub(text, "[^%d%.MKBmkb]", "")
    clean = string.upper(clean)
    
    local m = 1
    if string.find(clean, "M") then 
        m = 1000000 
        clean = string.gsub(clean, "M", "")
    elseif string.find(clean, "K") then 
        m = 1000 
        clean = string.gsub(clean, "K", "")
    elseif string.find(clean, "B") then 
        m = 1000000000 
        clean = string.gsub(clean, "B", "") 
    end
    
    local num = tonumber(clean)
    return (num and num * m) or math.huge
end

local function parseWaktu(text)
    if not text or text == "" then return 999 end
    local m, s = string.match(text, "(%d+)m%s*(%d+)s")
    if m and s then return (tonumber(m) * 60) + tonumber(s) end
    return 999
end

-- ========================================== --
--            MAIN LOOP (FIXED)               --
-- ========================================== --
task.spawn(function()
    while task.wait(0.05) do
        if not (config.PriceMode or config.TimeMode) then continue end
        
        local auctionUI = LocalPlayer.PlayerGui:FindFirstChild("Auction")
        if not auctionUI or not auctionUI.Enabled then continue end
        
        local scrollFrame = auctionUI.Frame:FindFirstChild("ScrollingFrame")
        if not scrollFrame then continue end
        
        for _, lot in pairs(scrollFrame:GetChildren()) do
            if lot:IsA("Frame") and lot.Name:match("^Lot_") then
                -- ===== EXTRACT LOT ID =====
                local lotId = lot.Name:match("Lot_(.+)")  -- "auction:1783141200:0"
                if not lotId then continue end
                
                -- ===== GET MAIN_FRAME =====
                local mainFrame = lot:FindFirstChild("Main_Frame", true)
                if not mainFrame then continue end
                
                -- ===== GET ITEM NAME =====
                local itemNameObj = mainFrame:FindFirstChild("ItemName", true)
                if not itemNameObj then continue end
                
                -- ItemName -> TextLabel -> .Text
                local itemNameLabel = itemNameObj:FindFirstChild("TextLabel")
                if not itemNameLabel then continue end
                local currentName = itemNameLabel.Text:lower()
                
                -- ===== MATCH ITEM =====
                local matchItem = nil
                for key, _ in pairs(config.PriceItems) do
                    if currentName:find(key) then matchItem = key break end
                end
                
                if not matchItem then continue end
                
                -- ===== GET PRICE =====
                local buyBtn = mainFrame:FindFirstChild("BuyButton", true)
                if not buyBtn then continue end
                
                -- BuyButton -> Text -> TextLabel -> .Text
                local priceObj = buyBtn:FindFirstChild("Text")
                if not priceObj then continue end
                
                local priceLabel = priceObj:FindFirstChild("TextLabel")
                if not priceLabel then continue end
                
                local hrg = parseHarga(priceLabel.Text)
                
                -- ===== GET TIME =====
                -- Cari di Refresh -> Timer
                local refreshObj = mainFrame:FindFirstChild("Refresh", true)
                local timerObj = nil
                if refreshObj then
                    timerObj = refreshObj:FindFirstChild("Timer")
                end
                
                -- Fallback: cari Timer recursive
                if not timerObj then
                    timerObj = mainFrame:FindFirstChild("Timer", true)
                end
                
                local wkt = parseWaktu(timerObj and timerObj.Text)
                
                -- ===== CHECK TRIGGER =====
                local executeBuy = false
                
                if config.PriceMode and config.PriceItems[matchItem] and hrg <= config.PriceLimit then
                    executeBuy = true
                    print(string.format("[TRIGGER PRICE] %s | Harga: %d <= Target: %d | LotID: %s", currentName, hrg, config.PriceLimit, lotId))
                end
                
                if config.TimeMode and config.TimeItems[matchItem] and wkt <= config.TimeLimit then
                    executeBuy = true
                    print(string.format("[TRIGGER TIME] %s | Waktu: %d <= Target: %d | LotID: %s", currentName, wkt, config.TimeLimit, lotId))
                end
                
                -- ===== EXECUTE BUY (FIXED) =====
                if executeBuy and lotId then
                    print(string.format(">>> MEMBELI: %s (LotID: %s, Harga: %d) <<<", currentName, lotId, hrg))
                    
                    local ok, err = pcall(function()
                        Networking.Auctioneer.PurchaseLot:Fire(lotId, hrg)
                    end)
                    
                    if ok then
                        print(string.format("[SUCCESS] PurchaseLot fired! (LotID: %s)", lotId))
                    else
                        print(string.format("[ERROR] PurchaseLot failed: %s", tostring(err)))
                    end
                    
                    task.wait(1) -- Delay untuk prevent spam
                end
            end
        end
    end
end)

