local function seedWindowIndex(t)
    return math.floor((t - SeedAnchor) / SeedPeriod) + 1
end

local function seedCurrent(item, t)
    local idx = seedWindowIndex(t)
    local q = item.q[idx]
    if q and q > 0 then
        local windowEnd = SeedAnchor + idx * SeedPeriod
        return q, math.max(0, windowEnd - t)
    end
    return nil, nil
end

local function seedNext(item, t)
    local idx = seedWindowIndex(t)
    for k = math.max(1, idx + 1), #item.q do
        local q = item.q[k]
        if q and q > 0 then
            local startT = SeedAnchor + (k - 1) * SeedPeriod
            return q, math.max(0, startT - t)
        end
    end
    return nil, nil
end

