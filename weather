    end
end)

local function refresh()
    local cur = weatherAt(now())

    if cur and cur.name then
        nowLabel.Text = string.format("Now: %s %s", Icon[cur.name] or "", cur.name)
        nowLabel.TextColor3 = Color[cur.name] or Color3.fromRGB(230, 230, 230)
        phaseLabel.Text = string.format("Next phase: %s", clock(cur.secsLeft))
    else
        nowLabel.Text = "Now: Unknown / data expired"
        nowLabel.TextColor3 = Color3.fromRGB(255, 110, 110)
        phaseLabel.Text = "Need newer DATA.weather"
    end

    for _, name in ipairs(WatchOrder) do
        local nxt = nextByName(name, 2500)
        local row = rows[name]

        if row then
            if cur and cur.name == name then
                row.Text = string.format("%s %s: NOW (%s left)", Icon[name] or "•", name, clock(cur.secsLeft))
            elseif nxt then
                row.Text = string.format("%s %s: %s", Icon[name] or "•", name, shortDur(nxt.secs))
            else
                row.Text = string.format("%s %s: not in data", Icon[name] or "•", name)
            end
        end
    end

    local t = now()
    for _, item in ipairs(SeedItems) do
        local row = seedRows[item.name]
        if row then
            local curQty, curLeft = seedCurrent(item, t)
            if curQty then
                row.Text = string.format("• %s: NOW x%s (%s)", item.name, tostring(curQty), clock(curLeft))
            else
                local nextQty, nextLeft = seedNext(item, t)
                if nextQty then
                    row.Text = string.format("• %s: %s", item.name, shortDur(nextLeft))
                else
                    row.Text = string.format("• %s: not in data", item.name)
                end
            end
        end
    end
end

task.spawn(function()
    while screenGui.Parent do
        refresh()
        task.wait(1)
    end
end)

