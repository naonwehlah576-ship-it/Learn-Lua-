local function clock(sec)
    sec = math.max(0, math.floor(sec or 0))
    local m = math.floor(sec / 60)
    local s = sec % 60
    return string.format("%02d:%02d", m, s)
end

local function shortDur(sec)
    sec = math.max(0, math.floor(sec or 0))
    local d = math.floor(sec / 86400)
    local h = math.floor((sec % 86400) / 3600)
    local m = math.floor((sec % 3600) / 60)
    local s = sec % 60

    if d > 0 then
        return string.format("%dd %dh", d, h)
    elseif h > 0 then
        return string.format("%dh %dm", h, m)
    elseif m > 0 then
        return string.format("%dm %02ds", m, s)
    else
        return string.format("%ds", s)
    end
end

local function weatherAt(t)
    if not W or not W.clen then
        return nil
    end

    local cyc = math.floor(t / W.clen)
    local into = t - cyc * W.clen

    local pi = 1
    for i = 1, #W.phases do
        if into >= W.phases[i].offset then
            pi = i
        end
    end

    local idx = cyc - W.startCycle + 1
    local seqRow = W.seq[idx]
    local name = seqRow and seqRow[pi] or nil

    local nextOff
    if pi + 1 <= #W.phases then
        nextOff = W.phases[pi + 1].offset
    else
        nextOff = W.clen
    end

    return {
        name = name,
        phaseName = W.phases[pi].name,
        secsLeft = cyc * W.clen + nextOff - t,
        cyc = cyc,
        pi = pi
    }
end

local function upcomingWeather(maxSteps)
    local t = now()
    local out = {}
    local cur = weatherAt(t)

    if not cur then
        return out
    end

    local cyc = cur.cyc
    local pi = cur.pi

    for _ = 1, maxSteps do
        pi += 1
        if pi > #W.phases then
            pi = 1
            cyc += 1
        end

        local idx = cyc - W.startCycle + 1
        if idx < 1 or idx > #W.seq then
            break
        end

        local row = W.seq[idx]
        local name = row and row[pi]
        if name then
            local startT = cyc * W.clen + W.phases[pi].offset
            table.insert(out, {
                name = name,
                secs = startT - t,
                cyc = cyc,
                pi = pi
            })
        end
    end

    return out
end

local function nextByName(targetName, maxSteps)
    for _, u in ipairs(upcomingWeather(maxSteps or 2500)) do
        if u.name == targetName then
            return u
        end
    end

    return nil
end


