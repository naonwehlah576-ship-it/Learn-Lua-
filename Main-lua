print("Fly Script Loaded")

local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()
local hrp = char:WaitForChild("HumanoidRootPart")

local speedMultiplier = 3
local flying = false

-- GUI
local gui = Instance.new("ScreenGui",game.CoreGui)
gui.Name = "FlyMenu"

local frame = Instance.new("Frame",gui)
frame.Size = UDim2.new(0,200,0,180)
frame.Position = UDim2.new(0.05,0,0.4,0)
frame.BackgroundColor3 = Color3.fromRGB(30,30,30)

local flyBtn = Instance.new("TextButton",frame)
flyBtn.Size = UDim2.new(1,0,0,40)
flyBtn.Text = "FLY: OFF"

local speedBtn = Instance.new("TextButton",frame)
speedBtn.Position = UDim2.new(0,0,0,40)
speedBtn.Size = UDim2.new(1,0,0,40)
speedBtn.Text = "SPEED x3"

local submitBtn = Instance.new("TextButton",frame)
submitBtn.Position = UDim2.new(0,0,0,80)
submitBtn.Size = UDim2.new(1,0,0,40)
submitBtn.Text = "GO SUBMIT"

local closeBtn = Instance.new("TextButton",frame)
closeBtn.Position = UDim2.new(0,0,0,120)
closeBtn.Size = UDim2.new(1,0,0,40)
closeBtn.Text = "CLOSE"

-- fly toggle
flyBtn.MouseButton1Click:Connect(function()

flying = not flying

if flying then
flyBtn.Text = "FLY: ON"
else
flyBtn.Text = "FLY: OFF"
end

end)

-- fly system
game:GetService("RunService").RenderStepped:Connect(function()

if flying and hrp then

local move = Vector3.new(0,0,0)

if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.W) then
move = move + workspace.CurrentCamera.CFrame.LookVector
end

if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.S) then
move = move - workspace.CurrentCamera.CFrame.LookVector
end

if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.A) then
move = move - workspace.CurrentCamera.CFrame.RightVector
end

if game:GetService("UserInputService"):IsKeyDown(Enum.KeyCode.D) then
move = move + workspace.CurrentCamera.CFrame.RightVector
end

hrp.Velocity = move * (60 * speedMultiplier)

end

end)

-- go to submit
submitBtn.MouseButton1Click:Connect(function()

local converter = workspace:FindFirstChild("PhantomConverter")

if converter then

local target = converter:GetPivot().Position

while (hrp.Position - target).Magnitude > 5 do

hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(target + Vector3.new(0,10,0)),0.05)

task.wait()

end

end

end)

closeBtn.MouseButton1Click:Connect(function()
gui:Destroy()
end)
