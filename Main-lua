local title = Instance.new("TextLabel")
title.Size = UDim2.new(1,0,0,30)
title.Text = "Fly To Phantom Cannon"
title.TextColor3 = Color3.new(1,1,1)
title.BackgroundColor3 = Color3.fromRGB(40,40,40)
title.Parent = frame

local fly = Instance.new("TextButton")
fly.Size = UDim2.new(0.45,0,0,35)
fly.Position = UDim2.new(0.05,0,1,-45)
fly.Text = "FLY x3"
fly.BackgroundColor3 = Color3.fromRGB(60,120,60)
fly.Parent = frame

local close = Instance.new("TextButton")
close.Size = UDim2.new(0.45,0,0,35)
close.Position = UDim2.new(0.5,0,1,-45)
close.Text = "CLOSE"
close.BackgroundColor3 = Color3.fromRGB(120,60,60)
close.Parent = frame

local flying = false

fly.MouseButton1Click:Connect(function()

    if flying then return end
    flying = true

    local cannon = workspace:FindFirstChild("PhantomMap")
        and workspace.PhantomMap:FindFirstChild("GhostCannon")

    if not cannon then
        flying = false
        return
    end

    local target

    if cannon:IsA("Model") then
        target = cannon:GetPivot().Position
    else
        target = cannon.Position
    end

    while flying and (hrp.Position - target).Magnitude > 5 do

        local dir = (target - hrp.Position).Unit
        hrp.CFrame = hrp.CFrame + dir * (3 * 10)

        task.wait()

    end

    flying = false

end)

close.MouseButton1Click:Connect(function()

    flying = false
    gui:Destroy()

end)
