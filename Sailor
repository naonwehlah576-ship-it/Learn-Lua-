    ScreenGui:Destroy()
end)

StartBtn.MouseButton1Click:Connect(function()
    running = not running
    if running then
        StartBtn.Text = "⏹ STOP TP"
        StartBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        StatusLabel.Text = "Status: Running..."
        StatusLabel.TextColor3 = Color3.fromRGB(100, 220, 100)
    else
        StartBtn.Text = "▶ START TP"
        StartBtn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        StatusLabel.Text = "Status: Idle"
        StatusLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

-- ================== AUTO EQUIP LOOP ==================
task.spawn(function()
    while true do
        task.wait(0.5)
        if not getAutoEquip() then continue end
        local char = player.Character
        if not char then continue end
        local humanoid = char:FindFirstChild("Humanoid")
        if not humanoid then continue end
        local tool = player.Backpack:FindFirstChild("True Manipulator")
        if tool then
            pcall(function() humanoid:EquipTool(tool) end)
        end
    end
end)

-- ================== TP LOOP ==================
task.spawn(function()
    local idx = 1
    while true do
        task.wait(0.1)
        if not running then continue end
        local char = player.Character
        if not char then continue end
        local root = char:FindFirstChild("HumanoidRootPart")
        if not root then continue end
        StatusLabel.Text = "TP ke: " .. locNames[idx]
        root.CFrame = CFrame.new(locations[idx])
        idx = idx % #locations + 1
        task.wait(delay)
    end
end)

-- ================== SKILL LOOP ==================
local skillRemote = ReplicatedStorage:WaitForChild("AbilitySystem"):WaitForChild("Remotes"):WaitForChild("RequestAbility")
local skills = {
    { id = 1, getState = getZ },
    { id = 2, getState = getX },
    { id = 3, getState = getC },
    { id = 4, getState = getV },
    { id = 5, getState = getF },
}

task.spawn(function()
    while true do
        task.wait(0.1)
        for _, skill in ipairs(skills) do
            if skill.getState() then
                pcall(function() skillRemote:FireServer(skill.id) end)
            end
        end
    end
end)
