-- ================== LOGIC ==================
local running = true
local delay = 0.5

local locations = {
    Vector3.new(-326.2, -3.7, -117.5),
    Vector3.new(-3075.8, 7.5, -664.8),
    Vector3.new(-1579.2, 2.7, 1843.3),
}
local locNames = {"Lokasi 1", "Lokasi 2", "Lokasi 3"}

delayBox:GetPropertyChangedSignal("Text"):Connect(function()
    delay = tonumber(delayBox.Text) or 0.5
end)

