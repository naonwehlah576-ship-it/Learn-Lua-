local function runWithToolLock(taskName, callback)
    while ToolBusy and gui.Parent do
        task.wait(0.05)
    end

    if not gui.Parent then
        return
    end

    ToolBusy = true
    farmlog(taskName, "started")

    local ok, err = pcall(callback)
    if not ok then
        farmwarn(taskName, "error:", err)
    end

    ToolBusy = false
    farmlog(taskName, "finished")
end

local function getToolByType(attributeName, targetName)
    local char = LocalPlayer.Character
    local backpack = LocalPlayer:FindFirstChild("Backpack")

    if char then
        for _, item in pairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local attr = item:GetAttribute(attributeName)
                if item.Name == targetName or attr == targetName then
                    return item
                end
            end
        end
    end

    if backpack then
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") then
                local attr = item:GetAttribute(attributeName)
                if item.Name == targetName or attr == targetName then
                    return item
                end
            end
        end
    end

    return nil
end

local function equipTool(tool)
    if not tool then
        return nil
    end

    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hum = char and char:FindFirstChildOfClass("Humanoid")

    if hum and tool.Parent ~= char then
        hum:EquipTool(tool)
        task.wait(0.25)
    end

    char = LocalPlayer.Character
    if not char then
        return nil
    end

    return char:FindFirstChild(tool.Name)
end

local function getMyPlot()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if not plotId then
        farmwarn("PlotId tidak ditemukan")
        return nil, nil
    end

    local gardens = workspace:FindFirstChild("Gardens")
    if not gardens then
        farmwarn("workspace.Gardens tidak ditemukan")
        return nil, nil
    end

    local myPlot = gardens:FindFirstChild("Plot" .. tostring(plotId))
    if not myPlot then
        farmwarn("Plot tidak ditemukan:", "Plot" .. tostring(plotId))
        return nil, nil
    end

    return myPlot, tonumber(plotId)
end

local function getPlantsFolder()
    local myPlot = getMyPlot()
    if not myPlot then
        return nil
    end

    local plants = myPlot:FindFirstChild("Plants")
    if not plants then
        farmwarn("Plants folder tidak ditemukan di", myPlot.Name)
        return nil
    end

    return plants
end

local function getPlantPosition(plant)
    if plant:IsA("Model") then
        if plant.PrimaryPart then
            return plant.PrimaryPart.Position
        end

        local ok, cf = pcall(function()
            return plant:GetPivot()
        end)

        if ok and cf then
            return cf.Position
        end
    elseif plant:IsA("BasePart") then
        return plant.Position
    end

    return nil
end

local function getPlantAreaParts(myPlot)
    local parts = {}

    for _, obj in pairs(myPlot:GetDescendants()) do
        if obj:IsA("BasePart") and CollectionService:HasTag(obj, "PlantArea") then
            table.insert(parts, obj)
        end
    end

    return parts
end

local function closestTopPointOnPart(part, worldPos)
    local localPos = part.CFrame:PointToObjectSpace(worldPos)

    local x = math.clamp(localPos.X, -part.Size.X / 2, part.Size.X / 2)
    local z = math.clamp(localPos.Z, -part.Size.Z / 2, part.Size.Z / 2)
    local y = part.Size.Y / 2

    return part.CFrame:PointToWorldSpace(Vector3.new(x, y, z))
end

local function getSprinklerPlacePosition(myPlot, plantPos, offsetIndex)
    local offset = SprinklerOffsets[offsetIndex] or SprinklerOffsets[1]
    local desired = plantPos + offset
    local parts = getPlantAreaParts(myPlot)

    local bestPos = nil
    local bestDist = math.huge

    for _, part in pairs(parts) do
        local pos = closestTopPointOnPart(part, desired)
        local dist = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(desired.X, 0, desired.Z)).Magnitude

        if dist < bestDist then
            bestDist = dist
            bestPos = pos
        end
    end

    if bestPos then
        return bestPos
    end

    return Vector3.new(desired.X, 142.602, desired.Z)
end

local function isTooCloseToSprinkler(myPlot, pos)
    for _, obj in pairs(myPlot:GetDescendants()) do
        if obj:IsA("Model") and SprinklerTypeSet[obj.Name] and obj.PrimaryPart then
            if (obj.PrimaryPart.Position - pos).Magnitude < 1 then
                return true
            end
        end
    end

    return false
end

local function findOneTargetPlant(plantsFolder)
    for _, plant in pairs(plantsFolder:GetChildren()) do
        local seedName = plant:GetAttribute("SeedName")

        if seedName and config.Targets[seedName] then
            local pos = getPlantPosition(plant)

            if pos then
                return plant, seedName, pos
            end
        end
    end

    return nil, nil, nil
end

local function doWateringCycle()
    if not Networking.WateringCan or not Networking.WateringCan.UseWateringCan then
        farmwarn("Remote WateringCan.UseWateringCan tidak ditemukan")
        return
    end

    local tool = getToolByType("WateringCan", config.WaterCanType)
    if not tool then
        farmwarn("Watering can tidak ditemukan:", config.WaterCanType)
        return
    end

    local equipped = equipTool(tool)
    if not equipped then
        farmwarn("Gagal equip watering can:", config.WaterCanType)
        return
    end

    local canName = equipped:GetAttribute("WateringCan") or config.WaterCanType
    local plantsFolder = getPlantsFolder()

    if not plantsFolder then
        return
    end

    local watered = 0

    for _, plant in pairs(plantsFolder:GetChildren()) do
        if not config.AutoWater then
            break
        end

        local seedName = plant:GetAttribute("SeedName")
        if seedName and config.Targets[seedName] then
            local pos = getPlantPosition(plant)

            if pos then
                local ok, err = pcall(function()
                    Networking.WateringCan.UseWateringCan:Fire(pos - Vector3.new(0, 0.3, 0), canName, equipped)
                end)

                if ok then
                    watered += 1
                    farmlog("Watered:", seedName, "| Can:", canName)
                else
                    farmwarn("Water fire gagal:", seedName, err)
                end

                task.wait(0.05)
            end
        end
    end

    if watered == 0 then
        farmlog("Watering: tidak ada target plant cocok")
    end
end

local function placeOneSprinkler(sprinklerType, offsetIndex, myPlot, plotId, seedName, plantPos)
    local tool = getToolByType("Sprinkler", sprinklerType)
    if not tool then
        farmwarn("Sprinkler tidak ditemukan / habis:", sprinklerType)
        return false, "NO_TOOL"
    end

    local equipped = equipTool(tool)
    if not equipped then
        farmwarn("Gagal equip sprinkler:", sprinklerType)
        return false, "EQUIP_FAILED"
    end

    local sprinklerName = equipped:GetAttribute("Sprinkler") or sprinklerType
    local placePos = getSprinklerPlacePosition(myPlot, plantPos, offsetIndex)

    if isTooCloseToSprinkler(myPlot, placePos) then
        farmlog("Sprinkler skip: terlalu dekat:", sprinklerName)
        return false, "TOO_CLOSE"
    end

    local ok, err = pcall(function()
        Networking.Place.PlaceSprinkler:Fire(placePos, sprinklerName, equipped, plotId)
    end)

    if ok then
        farmlog("Placed sprinkler:", sprinklerName, "| Near:", seedName)
        task.wait(0.25)
        return true, "PLACED"
    else
        farmwarn("PlaceSprinkler gagal:", sprinklerName, err)
        return false, "FIRE_FAILED"
    end
end

local function doSprinklerCycle()
    if not Networking.Place or not Networking.Place.PlaceSprinkler then
        farmwarn("Remote Place.PlaceSprinkler tidak ditemukan")
        return
    end

    local myPlot, plotId = getMyPlot()
    if not myPlot or not plotId then
        return
    end

    local plantsFolder = myPlot:FindFirstChild("Plants")
    if not plantsFolder then
        farmwarn("Plants folder tidak ditemukan")
        return
    end

    local plant, seedName, plantPos = findOneTargetPlant(plantsFolder)
    if not plant then
        farmlog("Sprinkler: tidak ada target plant cocok")
        return
    end

    if config.SprinklerType == "ALL SPRINKLER" then
        local foundAnyTool = false
        local placedCount = 0

        for i, sprinklerType in ipairs(RealSprinklerTypes) do
            if not config.AutoSprinkler then
                break
            end

            local tool = getToolByType("Sprinkler", sprinklerType)
            if tool then
                foundAnyTool = true
                local placed = placeOneSprinkler(sprinklerType, i, myPlot, plotId, seedName, plantPos)
                if placed then
                    placedCount += 1
                end
            else
                farmwarn("ALL SPRINKLER skip:", sprinklerType)
            end

            task.wait(0.1)
        end

        if not foundAnyTool then
            farmwarn("ALL SPRINKLER habis, auto sprinkler OFF")
            config.AutoSprinkler = false
            refreshFarmToggles()
            SaveConfig()
        end

        farmlog("ALL SPRINKLER cycle done | placed:", placedCount)
        return
    end

    local placed, reason = placeOneSprinkler(config.SprinklerType, 1, myPlot, plotId, seedName, plantPos)

    if reason == "NO_TOOL" or reason == "EQUIP_FAILED" then
        config.AutoSprinkler = false
        refreshFarmToggles()
        SaveConfig()
    end
end

--// FRUIT PRICE CORE
local function normalizeText(s)
    s = tostring(s or "")
    s = s:gsub("^%s+", ""):gsub("%s+$", "")
    return s
end

local function normalizeFruitName(name)
    name = normalizeText(name)
    name = name:gsub("%s+", " ")
    return name
end

local function parseKgFromText(text)
    text = tostring(text or "")

    local num = text:match("([%d%.]+)%s*kg")
    if num then
        return tonumber(num)
    end

    num = text:match("%[([%d%.]+)%s*kg%]")
    if num then
        return tonumber(num)
    end

    return nil
end

local function parseFruitNameFromItem(item)
    local fruitName = item:GetAttribute("FruitName") or item:GetAttribute("Fruit")
    if fruitName then
        return normalizeFruitName(fruitName)
    end

    local name = tostring(item.Name or "")
    name = name:gsub("%s*%b[]", "")
    return normalizeFruitName(name)
end

local function parseKgFromItem(item)
    local weight =
        item:GetAttribute("Weight")
        or item:GetAttribute("Kg")
        or item:GetAttribute("KG")
        or item:GetAttribute("Mass")

    if tonumber(weight) then
        return tonumber(weight)
    end

    return parseKgFromText(item.Name)
end

local function getBackpackGrid()
    local backpackGui = PlayerGui:FindFirstChild("BackpackGui")
    if not backpackGui then
        return nil, "BackpackGui not found"
    end

    local backpack = backpackGui:FindFirstChild("Backpack")
    if not backpack then
        return nil, "Backpack frame not found"
    end

    local inventory = backpack:FindFirstChild("Inventory")
    if not inventory then
        return nil, "Inventory not found"
    end

    local scrollingFrame = inventory:FindFirstChild("ScrollingFrame")
    if not scrollingFrame then
        return nil, "ScrollingFrame not found"
    end

    local grid = scrollingFrame:FindFirstChild("UIGridFrame")
    if not grid then
        return nil, "UIGridFrame not found"
    end

    return grid, nil
end

local function isTextObj(obj)
    return obj and (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox"))
end

local function getSlotInfo(slot)
    if not slot:IsA("GuiObject") then
        return nil
    end

    local toolName = slot:FindFirstChild("ToolName")
    local toolCount = slot:FindFirstChild("ToolCount")

    if not isTextObj(toolName) or not isTextObj(toolCount) then
        return nil
    end

    local fruitName = normalizeFruitName(toolName.Text)
    local kg = parseKgFromText(toolCount.Text)

    if fruitName == "" or not kg then
        return nil
    end

    return {
        Slot = slot,
        FruitName = fruitName,
        Kg = kg
    }
end

local function ensurePriceLabel(slot)
    local label = slot:FindFirstChild(config.FruitPriceTextName)

    if label and label:IsA("TextLabel") then
        return label
    end

    label = Instance.new("TextLabel")
    label.Name = config.FruitPriceTextName
    label.BackgroundTransparency = 1
    label.BorderSizePixel = 0
    label.Size = UDim2.new(1, 0, 0, 16)
    label.Position = UDim2.new(0, 0, 0, -1)
    label.ZIndex = 100
    label.Text = ""
    label.TextColor3 = Color3.fromRGB(0, 255, 80)
    label.TextStrokeTransparency = 0
    label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    label.Font = Enum.Font.GothamBold
    label.TextSize = 11
    label.TextScaled = false
    label.TextWrapped = false
    label.TextXAlignment = Enum.TextXAlignment.Center
    label.TextYAlignment = Enum.TextYAlignment.Center
    label.Parent = slot

    return label
end

local function isFruitItem(item)
    if not (item:IsA("Tool") or item:IsA("Configuration")) then
        return false
    end

    local id = item:GetAttribute("Id")
    if not id then
        return false
    end

    local fruitName = item:GetAttribute("FruitName") or item:GetAttribute("Fruit")
    local weight = item:GetAttribute("Weight")
    local mutation = item:GetAttribute("Mutation")
    local harvested = item:GetAttribute("HarvestedFruit")

    if harvested == true then
        return true
    end

    if fruitName and weight then
        return true
    end

    if fruitName and mutation and parseKgFromText(item.Name) then
        return true
    end

    if string.find(string.lower(item.Name), "kg") and fruitName then
        return true
    end

    return false
end

local function getAllFruitItems()
    local items = {}

    local function scan(containerName, container)
        if not container then
            return
        end

        for _, item in pairs(container:GetChildren()) do
            if isFruitItem(item) then
                table.insert(items, {
                    Item = item,
                    ClassName = item.ClassName,
                    Id = item:GetAttribute("Id"),
                    FruitName = parseFruitNameFromItem(item),
                    Kg = parseKgFromItem(item),
                    Mutation = item:GetAttribute("Mutation"),
                    Used = false
                })
            end
        end
    end

    scan("Backpack", LocalPlayer:FindFirstChild("Backpack"))
    scan("Character", LocalPlayer.Character)

    return items
end

local function getFruitPrice(fruitId)
    if not fruitId then
        return nil
    end

    local cached = priceCache[fruitId]
    if cached and os.clock() - cached.Time < 10 then
        return cached.Price
    end

    local ok, result = pcall(function()
        return Networking.NPCS.GetFruitBid:Fire(fruitId)
    end)

    if ok and type(result) == "table" and result.CurrentSellValue then
        local price = tonumber(result.CurrentSellValue)
        priceCache[fruitId] = {
            Price = price,
            Time = os.clock()
        }
        return price
    end

    pricewarn("GetFruitBid failed:", fruitId, result)
    return nil
end

local function buildItemList()
    local result = {}
    local rawItems = getAllFruitItems()

    pricelog("Fruit items found:", #rawItems)

    for _, info in ipairs(rawItems) do
        if info.Id and info.FruitName and info.FruitName ~= "" and info.Kg then
            local price = getFruitPrice(info.Id)

            if price then
                info.Price = price
                info.Used = false
                table.insert(result, info)
            end
        end

        task.wait(0.015)
    end

    return result
end

local function findBestItemForSlot(slotInfo, itemList)
    local best = nil
    local bestDiff = math.huge

    for _, info in ipairs(itemList) do
        if not info.Used and info.FruitName == slotInfo.FruitName and info.Kg then
            local diff = math.abs(info.Kg - slotInfo.Kg)

            if diff < bestDiff then
                best = info
                bestDiff = diff
            end
        end
    end

    if best and bestDiff <= config.KgTolerance then
        best.Used = true
        return best, bestDiff
    end

    return nil, bestDiff
end

local function collectSlots(grid)
    local slots = {}

    for _, slot in pairs(grid:GetChildren()) do
        local info = getSlotInfo(slot)
        if info then
            table.insert(slots, info)
        end
    end

    table.sort(slots, function(a, b)
        local aNum = tonumber(a.Slot.Name) or 0
        local bNum = tonumber(b.Slot.Name) or 0
        return aNum < bNum
    end)

    return slots
end

local function applyPricesToGui()
    local grid, err = getBackpackGrid()
    if not grid then
        pricewarn(err)
        return
    end

    local itemList = buildItemList()
    local slots = collectSlots(grid)

    local updated = 0

    for _, slotInfo in ipairs(slots) do
        local label = ensurePriceLabel(slotInfo.Slot)
        local match = findBestItemForSlot(slotInfo, itemList)

        if match and match.Price then
            label.Text = formatMoney(match.Price)
            label.Visible = true
            updated += 1
        else
            label.Text = ""
            label.Visible = false
        end
    end

    pricelog("Apply done. Slots:", #slots, "Updated:", updated)
end

--// AUCTION CORE
local lastBuyLot = {}
local function doAuctionLoop()
    if not isAnyAuctionEnabled() then
        return
    end

    if not isAuctionOpen() then
        startAuctionMonitor()
        return
    end

    local auctionUI = PlayerGui:FindFirstChild("Auction")
    if not auctionUI or not auctionUI.Enabled then
        return
    end

    local auctionFrame = auctionUI:FindFirstChild("Frame")
    if not auctionFrame then
        return
    end

    local scrollFrame = auctionFrame:FindFirstChild("ScrollingFrame")
    if not scrollFrame then
        return
    end

    for _, lot in pairs(scrollFrame:GetChildren()) do
        if lot:IsA("Frame") and lot.Name:match("^Lot_") then
            local lotId = lot.Name:match("Lot_(.+)")
            if not lotId then
                continue
            end

            if lastBuyLot[lotId] and os.clock() - lastBuyLot[lotId] < 1.5 then
                continue
            end

            local mainFrame = lot:FindFirstChild("Main_Frame", true)
            if not mainFrame then
                continue
            end

            local itemNameObj = mainFrame:FindFirstChild("ItemName", true)
            if not itemNameObj then
                continue
            end

            local itemNameLabel = itemNameObj:FindFirstChild("TextLabel")
            if not itemNameLabel then
                continue
            end

            local currentName = string.lower(itemNameLabel.Text)

            local matchItem = nil
            for itemKey in pairs(config.AuctionItems) do
                if currentName:find(itemKey, 1, true) then
                    matchItem = itemKey
                    break
                end
            end

            if not matchItem then
                continue
            end

            local itemSettings = config.AuctionItems[matchItem]
            if not itemSettings or not itemSettings.TimeEnabled then
                continue
            end

            local refreshObj = mainFrame:FindFirstChild("Refresh", true)
            local timerObj = nil
            if refreshObj then
                timerObj = refreshObj:FindFirstChild("Timer")
            end

            if not timerObj then
                timerObj = mainFrame:FindFirstChild("Timer", true)
            end

            local wkt = parseWaktu(timerObj and timerObj.Text)
            if wkt > itemSettings.TimeLimit then
                continue
            end

            local buyBtn = mainFrame:FindFirstChild("BuyButton", true)
            if not buyBtn then
                continue
            end

            local priceObj = buyBtn:FindFirstChild("Text")
            if not priceObj then
                continue
            end

            local priceLabel = priceObj:FindFirstChild("TextLabel")
            if not priceLabel then
                continue
            end

            local hrg = parseHarga(priceLabel.Text)

            auctionlog(string.format("[TRIGGER TIME] %s | Waktu: %ds <= %ds | LotID: %s | Harga: %d", currentName, wkt, itemSettings.TimeLimit, lotId, hrg))

            local ok, err = pcall(function()
                Networking.Auctioneer.PurchaseLot:Fire(lotId, hrg)
            end)

            lastBuyLot[lotId] = os.clock()

            if ok then
                auctionlog("[SUCCESS] PurchaseLot fired:", lotId)
            else
                auctionlog("[ERROR] PurchaseLot failed:", tostring(err))
            end

            task.wait(0.3)
        end
    end
end

