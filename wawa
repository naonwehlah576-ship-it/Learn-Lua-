local function startAuctionMonitor()
    if auctionCheckTask then
        return
    end

    auctionCheckTask = task.spawn(function()
        auctionlog("monitor started")

        while gui.Parent do
            if not isAnyAuctionEnabled() then
                break
            end

            task.wait(5)

            if isAnyAuctionEnabled() and not isAuctionOpen() then
                auctionlog("auction closed, reopening")
                openAuctionUI()
                task.wait(0.5)
            end
        end

        auctionCheckTask = nil
        auctionlog("monitor stopped")
    end)
end

