            end
        end

        if type(saved.Targets) == "table" then
            for k, v in pairs(saved.Targets) do
                if config.Targets[k] ~= nil then
                    config.Targets[k] = v
                end
            end
        end

        if type(saved.AuctionItems) == "table" then
            for itemKey, itemSettings in pairs(saved.AuctionItems) do
                if config.AuctionItems[itemKey] and type(itemSettings) == "table" then
                    if itemSettings.TimeEnabled ~= nil then
                        config.AuctionItems[itemKey].TimeEnabled = itemSettings.TimeEnabled
                    end
                    if itemSettings.TimeLimit ~= nil then
                        config.AuctionItems[itemKey].TimeLimit = itemSettings.TimeLimit
                    end
                end
            end
        end
    end
end

local function parseWaktu(text)
    if not text or text == "" then return 999 end

    text = tostring(text):lower()

    local m, s = string.match(text, "(%d+)%s*m%s*(%d+)%s*s")
    if m and s then
        return (tonumber(m) * 60) + tonumber(s)
    end

    local onlyM = string.match(text, "(%d+)%s*m")
    if onlyM then
        return tonumber(onlyM) * 60
    end

    local sec = tonumber(text:match("%d+"))
    return sec or 999
end

local function parseHarga(text)
    if not text or text == "" then return 0 end

    local clean = tostring(text):gsub("[^%d%.MKBmkb]", "")
    clean = clean:upper()

    local multi = 1
    if clean:find("B") then
        multi = 1000000000
        clean = clean:gsub("B", "")
    elseif clean:find("M") then
        multi = 1000000
        clean = clean:gsub("M", "")
    elseif clean:find("K") then
        multi = 1000
        clean = clean:gsub("K", "")
    end

    local num = tonumber(clean)
    return num and (num * multi) or 0
end

local function formatMoney(n)
    n = tonumber(n) or 0

    local abs = math.abs(n)
    local value = n
    local suffix = ""

    if abs >= 1e12 then
        value = n / 1e12
        suffix = "T"
    elseif abs >= 1e9 then
        value = n / 1e9
        suffix = "B"
    elseif abs >= 1e6 then
        value = n / 1e6
        suffix = "M"
    elseif abs >= 1e3 then
        value = n / 1e3
        suffix = "K"
    else
        return "$" .. tostring(math.floor(n))
    end

    local text
    if math.abs(value) >= 100 then
        text = string.format("%.0f", value)
    elseif math.abs(value) >= 10 then
        text = string.format("%.1f", value)
    else
        text = string.format("%.2f", value)
    end

    text = text:gsub("%.0+$", "")
    text = text:gsub("(%..-)0+$", "%1")

    return "$" .. text .. suffix
end

