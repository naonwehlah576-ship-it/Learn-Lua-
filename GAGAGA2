task.spawn(function()
    while task.wait(1) do
        if config.AutoPlant then
            local char = LocalPlayer.Character
            if not char then continue end

            local seedTool = nil

            for seedName, isSelected in pairs(config.SelectedPlantSeeds) do
                if isSelected then
                    local seedNameLower = string.lower(seedName)
                    for _, tool in pairs(char:GetChildren()) do
                        if tool:IsA("Tool") and string.find(string.lower(tool.Name), seedNameLower) then
                            seedTool = tool; break
                        end
                    end
                    if not seedTool and LocalPlayer:FindFirstChild("Backpack") then
                        for _, tool in pairs(LocalPlayer.Backpack:GetChildren()) do
                            if tool:IsA("Tool") and string.find(string.lower(tool.Name), seedNameLower) then
                                seedTool = tool; break
                            end
                        end
                    end
                    if seedTool then break end 
                end
            end

            if seedTool and seedTool:GetAttribute("SeedTool") then
                local seedValue = seedTool:GetAttribute("SeedTool")
                
                if seedTool.Parent ~= char then
                    seedTool.Parent = char
                    task.wait(0.2)
                end

                local plotId = LocalPlayer:GetAttribute("PlotId")
                if plotId then
                    local gardens = workspace:FindFirstChild("Gardens")
                    local myPlot = gardens and gardens:FindFirstChild("Plot" .. tostring(plotId))
                    
                    if myPlot and myPlot:FindFirstChild("Visual") then
                        local spacing = 2.5 
                        
                        for _, bed in pairs(myPlot.Visual:GetChildren()) do
                            if string.find(bed.Name, "BedSection") then
                                local bedCFrame, bedSize = bed:GetBoundingBox()
                                
                                for x = -bedSize.X/2 + spacing, bedSize.X/2 - spacing, spacing do
                                    for z = -bedSize.Z/2 + spacing, bedSize.Z/2 - spacing, spacing do
                                        if not config.AutoPlant then break end 
                                        
                                        local targetPos = (bedCFrame * CFrame.new(x, bedSize.Y/2, z)).Position
                                        
                                        if Networking and Networking.Plant and Networking.Plant.PlantSeed then
                                            Networking.Plant.PlantSeed:Fire(targetPos, seedValue, seedTool)
                                            task.wait(0.05) 
                                        end
                                    end
                                    if not config.AutoPlant then break end
                                end
                            end
                            if not config.AutoPlant then break end
                        end
                    end
                end
            else
                task.wait(2) 
            end
        end
    end
end)
