                                            end
                                            
                                            if currentPrice >= protectPrice then return end
                                        end

                                        print(string.format("💰 [SELL1-1] JUAL %s | %.3fkg | Harga: ¢%s", tostring(itemNameDbg), weight, tostring(currentPrice)))
                                        pcall(function()
                                            return Networking.NPCS.SellFruit and Networking.NPCS.SellFruit:Fire(fruitId)
                                        end)
                                    end)
                                end
                            end
                        end
                    end
                else
                    pcall(function() 
                        if Networking and Networking.NPCS and Networking.NPCS.SellAll then
                            if typeof(Networking.NPCS.SellAll) == "table" and Networking.NPCS.SellAll.Fire then 
                                Networking.NPCS.SellAll:Fire() 
                            elseif typeof(Networking.NPCS.SellAll) == "function" then 
                                Networking.NPCS.SellAll() 
                            end 
                        end
                    end)
                end
            end
        end
    end
end)

