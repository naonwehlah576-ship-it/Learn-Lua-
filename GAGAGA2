    local function doAuctionLoop()
        if not isAnyAuctionEnabled() then return end
        if not isAuctionOpen() then
            startAuctionMonitor()
            return
        end

        local auctionUI = PlayerGui:FindFirstChild("Auction")
        if not auctionUI or not auctionUI.Enabled then return end
        local auctionFrame = auctionUI:FindFirstChild("Frame")
        if not auctionFrame then return end
        local scrollFrame = auctionFrame:FindFirstChild("ScrollingFrame")
        if not scrollFrame then return end

        for _, lot in pairs(scrollFrame:GetChildren()) do
            if lot:IsA("Frame") and lot.Name:match("^Lot_") then
                local lotId = lot.Name:match("Lot_(.+)")
                if not lotId then continue end
                if lastBuyLot[lotId] and os.clock() - lastBuyLot[lotId] < 1.5 then continue end

                local mainFrame = lot:FindFirstChild("Main_Frame", true)
                if not mainFrame then continue end

                local itemNameObj = mainFrame:FindFirstChild("ItemName", true)
                if not itemNameObj then continue end

                local itemNameLabel = itemNameObj:FindFirstChild("TextLabel")
                if not itemNameLabel then continue end

                local currentName = string.lower(itemNameLabel.Text)
                local matchItem = nil

                for itemKey in pairs(ToolsConfig.AuctionItems) do
                    if currentName:find(itemKey, 1, true) then
                        matchItem = itemKey
                        break
                    end
                end

                if not matchItem then continue end
                local itemSettings = ToolsConfig.AuctionItems[matchItem]
                if not itemSettings or not itemSettings.TimeEnabled then continue end

                local refreshObj = mainFrame:FindFirstChild("Refresh", true)
                local timerObj = nil
                if refreshObj then timerObj = refreshObj:FindFirstChild("Timer") end
                if not timerObj then timerObj = mainFrame:FindFirstChild("Timer", true) end

                local wkt = parseWaktu(timerObj and timerObj.Text)
                if wkt > itemSettings.TimeLimit then continue end

                local buyBtn = mainFrame:FindFirstChild("BuyButton", true)
                if not buyBtn then continue end
                local priceObj = buyBtn:FindFirstChild("Text")
                if not priceObj then continue end
                local priceLabel = priceObj:FindFirstChild("TextLabel")
                if not priceLabel then continue end

                local hrg = parseHarga(priceLabel.Text)
                pcall(function()
                    Networking.Auctioneer.PurchaseLot:Fire(lotId, hrg)
                end)

                lastBuyLot[lotId] = os.clock()
                task.wait(0.3)
            end
        end
    end


