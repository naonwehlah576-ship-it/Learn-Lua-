local pendingFavoriteChecks = 0
local lastFavoriteActionTime = 0

task.spawn(function()
    local backpack = LocalPlayer:WaitForChild("Backpack")

    local function scanAndFavoriteItem(item)
        if not item:IsA("Tool") then return end

        pendingFavoriteChecks += 1
        lastItemAddedTime = os.clock()

        local ok, errMsg = pcall(function()
            task.wait(0.2) 
            if not config.AutoFavorite then return end

            local isFruit = item:GetAttribute("HarvestedFruit") == true or item:GetAttribute("Fruit") ~= nil
            if not isFruit then return end

            local targetKg = tonumber(config.FavoriteThreshold) or 100
            local targetPrice = tonumber(config.FavoritePrice) or 0

            local rawName = item:GetAttribute("Fruit") or item.Name
            local fruitName = string.gsub(rawName, "%s*%[%d+%.?%d*k?g?%]", "")
            fruitName = string.match(fruitName, "^%s*(.-)%s*$") 

            local weight = item:GetAttribute("Weight") or 0

            local isNameMatch = config.SelectedFavSeeds[fruitName] == true
            local isHeavy = (type(weight) == "number" and weight >= targetKg)

            local isPricy = false
            local price = item:GetAttribute("FruitValue") or 0 
            if not isNameMatch and not isHeavy and targetPrice > 0 then
                local fruitIdForBid = item:GetAttribute("Id")
                if fruitIdForBid and Networking and Networking.NPCS and Networking.NPCS.GetFruitBid then
                    local success, bidData = pcall(function()
                        return Networking.NPCS.GetFruitBid:Fire(fruitIdForBid)
                    end)
                    if success and type(bidData) == "table" and bidData.CurrentSellValue then
                        price = tonumber(bidData.CurrentSellValue) or price 
                        isPricy = price >= targetPrice
                    end
                end
            end

            if (isNameMatch or isHeavy or isPricy) and item:GetAttribute("IsFavorite") ~= true then
                local fruitId = item:GetAttribute("Id")
                if fruitId then
                    pcall(function()
                        if Networking and Networking.Backpack and Networking.Backpack.SetFruitFavorite then
                            Networking.Backpack.SetFruitFavorite:Fire(fruitId, true)
                        end
                        item:SetAttribute("IsFavorite", true)
                    end)
                    lastFavoriteActionTime = os.clock()
                    print("🔒 [TURBO FAV] Berhasil mengunci: " .. fruitName .. " (" .. tostring(weight) .. "kg | ¢" .. tostring(price) .. ")")
                end
            end
        end)

        pendingFavoriteChecks -= 1
        if not ok then warn("[AutoFavorite] error saat proses item:", errMsg) end
    end

    for _, item in pairs(backpack:GetChildren()) do task.spawn(scanAndFavoriteItem, item) end
    backpack.ChildAdded:Connect(function(item) task.spawn(scanAndFavoriteItem, item) end)
end)

