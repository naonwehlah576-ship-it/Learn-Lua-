local function getGardenSpawnPoint()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if plotId then
        local gardensFolder = workspace:FindFirstChild("Gardens")
        if gardensFolder then
            local myPlot = gardensFolder:FindFirstChild("Plot" .. tostring(plotId))
            if myPlot then return myPlot:FindFirstChild("SpawnPoint") end
        end
    end
    return nil
end

local function getPromptLocation(prompt)
    if not prompt or not prompt.Parent then return nil, nil end
    if prompt.Parent:IsA("BasePart") then return prompt.Parent.Position, prompt.Parent.CFrame
    elseif prompt.Parent:IsA("Attachment") then return prompt.Parent.WorldPosition, prompt.Parent.WorldCFrame
    elseif prompt.Parent:IsA("Model") then return prompt.Parent:GetPivot().Position, prompt.Parent:GetPivot()
    else
        local part = prompt:FindFirstAncestorWhichIsA("BasePart")
        if part then return part.Position, part.CFrame end
    end
    return nil, nil
end

local function getCurrentMoney()
    local sheckles = LocalPlayer:FindFirstChild("leaderstats") and LocalPlayer.leaderstats:FindFirstChild("Sheckles")
    return sheckles and sheckles.Value or 0
end

local currentTween = nil
local currentTweenTarget = nil
local noclipConnection = nil

local function toggleNoclip(state)
    local char = LocalPlayer.Character
    if not char then return end
    if state then
        if not noclipConnection then
            noclipConnection = RunService.Stepped:Connect(function()
                for _, part in pairs(char:GetDescendants()) do
                    if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end
                end
            end)
        end
    else
        if noclipConnection then noclipConnection:Disconnect(); noclipConnection = nil end
    end
end

local function stopTween()
    if currentTween then currentTween:Cancel(); currentTween = nil end
    local char = LocalPlayer.Character
    if char and char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.Anchored = false end
    toggleNoclip(false)
    currentTweenTarget = nil
end

local function moveToLocation(targetCFrame)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    
    if config.MoveMethod == "TP" then
        -- MODE TELEPORT INSTAN
        stopTween()
        hrp.CFrame = targetCFrame
        task.wait(0.1) -- Jeda bentar biar server nangkep perpindahan lu
    else
        -- MODE TWEEN
        if currentTweenTarget and (currentTweenTarget - targetCFrame.Position).Magnitude < 10 then return end
        
        local speed = tonumber(config.TweenSpeed) or 50
        local distance = (hrp.Position - targetCFrame.Position).Magnitude
        local tInfo = TweenInfo.new(distance / speed, Enum.EasingStyle.Linear)
        
        if currentTween then currentTween:Cancel() end
        
        toggleNoclip(true)
        hrp.Anchored = true 
        
        currentTweenTarget = targetCFrame.Position
        currentTween = TweenService:Create(hrp, tInfo, {CFrame = targetCFrame})
        currentTween.Completed:Connect(function()
            hrp.Anchored = false
            toggleNoclip(false)
            currentTweenTarget = nil
        end)
        currentTween:Play()
    end
end

local function scanForRare()
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.ActionText == "CLAIM" and (obj.ObjectText == "Gold Seed" or obj.ObjectText == "Rainbow Seed") then
            return obj
        end
    end
    return nil
end

local function scanForPet()
    local targetPetName = nil
    for pet, isSelected in pairs(config.SelectedPets) do
        if isSelected then targetPetName = pet break end
    end
    if targetPetName and PetData[targetPetName] then
        local targetPriceStr = PetData[targetPetName].PriceStr
        for _, obj in pairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") and obj.ActionText == "Buy" and obj.ObjectText == targetPriceStr then
                return obj, PetData[targetPetName].PriceNum
            end
        end
    end
    return nil, 0
end

