    local function fixMailCategory(category, itemName)
        local fixedCategory = category

        if fixedCategory == "Seed" then
            fixedCategory = "Seeds"
        elseif fixedCategory == "HarvestedFruit" then
            fixedCategory = "HarvestedFruits"
        end

        if fixedCategory == "Gear" then
            if string.match(itemName, "Trowel") then
                fixedCategory = "Trowels"
            elseif string.match(itemName, "Sprinkler") then
                fixedCategory = "Sprinklers"
            elseif string.match(itemName, "Watering Can") or string.match(itemName, "Wateringcan") then
                fixedCategory = "WateringCans"
            elseif string.match(itemName, "Mushroom") then
                fixedCategory = "Mushrooms"
            elseif string.match(itemName, "Gnome") then
                fixedCategory = "Gnomes"
            elseif string.match(itemName, "Raccoon") then
                fixedCategory = "Raccoons"
            elseif string.match(itemName, "Crate") then
                fixedCategory = "Crates"
            elseif string.match(itemName, "Prop") then
                fixedCategory = "Props"
            elseif string.match(itemName, "Seed Pack") or string.match(itemName, "SeedPack") then
                fixedCategory = "SeedPacks"
            end
        end

        return fixedCategory
    end

