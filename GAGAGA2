-- AUTO LEAVE IF EVENT HAPPEN
-- Event pilihan: Snowfall/Snowman dan Goldmoon.
-- Action bisa Leave (Kick) atau Reconnect (logic sama seperti Auto Reconnect bawaan: Teleport ke same place).
-- =====================================================================
local autoLeaveTriggered = false

local function normalizeEventName(name)
    return string.lower(tostring(name or "")):gsub("%s+", ""):gsub("_", ""):gsub("%-", "")
end

local function eventNameMatchesSnow(name)
    local n = normalizeEventName(name)
    -- Jangan pakai contains terlalu luas, biar object aneh/preview nggak false trigger.
    return n == "snowfall"
        or n == "snowman"
        or n == "snowevent"
        or n == "snowfallevent"
        or n == "snowmanevent"
end

local function eventNameMatchesGoldmoon(name)
    local n = normalizeEventName(name)
    return n == "goldmoon"
        or n == "goldmoonevent"
end

local function scanWorkspaceAttributesForLeaveEvent()
    local attrNames = {"Weather", "CurrentWeather", "ActiveWeather", "Event", "CurrentEvent", "WeatherEvent"}
    for _, attrName in ipairs(attrNames) do
        local val = workspace:GetAttribute(attrName)
        if val ~= nil then
            local text = tostring(val)
            if config.LeaveOnSnowEvent and eventNameMatchesSnow(text) then
                return "Snowfall/Snowman attribute: " .. text
            end
            if config.LeaveOnGoldmoonEvent and eventNameMatchesGoldmoon(text) then
                return "Goldmoon attribute: " .. text
            end
        end
    end
    return nil
end

local function scanWorkspaceObjectsForLeaveEvent()
    -- Aman: cuma cek object event level atas workspace.
    -- Descendants dimatiin karena bisa false trigger dari Preview/Temporary/Attachment.
    for _, obj in ipairs(workspace:GetChildren()) do
        if obj.Name ~= "Temporary" then
            if config.LeaveOnSnowEvent and eventNameMatchesSnow(obj.Name) then
                return "Snowfall/Snowman object: " .. obj.Name
            end
            if config.LeaveOnGoldmoonEvent and eventNameMatchesGoldmoon(obj.Name) then
                return "Goldmoon object: " .. obj.Name
            end
        end
    end

    return nil
end

local function getWeatherValuesLeaveReason()
    local weatherValues = ReplicatedStorage:FindFirstChild("WeatherValues")
    if not weatherValues then return nil end

    local function getLeft(name)
        local endTime = weatherValues:GetAttribute(name .. "_EndTime") or 0
        local left = math.max(0, endTime - DateTime.now().UnixTimestamp)
        return left
    end

    local function isPlaying(name)
        return weatherValues:GetAttribute(name .. "_Playing") == true
    end

    if config.LeaveOnSnowEvent then
        local snowNames = {"Snowfall", "Snowman", "Snow"}
        for _, weatherName in ipairs(snowNames) do
            if isPlaying(weatherName) then
                return weatherName .. " WeatherValues active, left " .. tostring(getLeft(weatherName)) .. "s"
            end
        end

        -- fallback: baca semua attribute yang sedang Playing, cocokkan nama snow.
        for attr, value in pairs(weatherValues:GetAttributes()) do
            if value == true and string.sub(attr, -8) == "_Playing" then
                local weatherName = string.sub(attr, 1, #attr - 8)
                if eventNameMatchesSnow(weatherName) then
                    return weatherName .. " WeatherValues active, left " .. tostring(getLeft(weatherName)) .. "s"
                end
            end
        end
    end

    if config.LeaveOnGoldmoonEvent then
        local goldNames = {"Goldmoon", "GoldMoon"}
        for _, weatherName in ipairs(goldNames) do
            if isPlaying(weatherName) then
                return weatherName .. " WeatherValues active, left " .. tostring(getLeft(weatherName)) .. "s"
            end
        end
    end

    return nil
end

local function getAutoLeaveEventReason()
    -- Snowfall/Snowman official detect path: ReplicatedStorage.WeatherValues:<Weather>_Playing.
    local reason = getWeatherValuesLeaveReason()
    if reason then return reason end

    -- Workspace direct still needed for rare events like Goldmoon in the old hub logic.
    reason = scanWorkspaceAttributesForLeaveEvent()
    if reason then return reason end
    return scanWorkspaceObjectsForLeaveEvent()
end

task.spawn(function()
    while task.wait(0.75) do
        if config.AutoLeaveEvent and not autoLeaveTriggered then
            local reason = getAutoLeaveEventReason()
            if reason then
