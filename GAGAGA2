-- MESIN LAMA: SPIRAL FLIGHT (TWEEN)
-- ==========================================
local function startSpiralFlight(targetObj)
    if currentOrbitConnection then return end 
    
    stopMovement() 
    
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    
    toggleNoclip(true)
    hrp.Anchored = true 
    
    local orbitRadius = 4 
    local orbitSpeed = 5  
    local approachSpeed = tonumber(config.TweenSpeed) or 50 
    
    currentOrbitConnection = RunService.Heartbeat:Connect(function(deltaTime)
        -- FIX PENTING: Cek targetObj.Enabled!
        if not targetObj or not targetObj.Parent or not targetObj:IsDescendantOf(workspace) or not targetObj.Enabled then
            stopMovement()
            Hunt.State = "IDLE" 
            Hunt.Target = nil
            return
        end
        
        local targetPos, _ = getPromptLocation(targetObj)
        if not targetPos then stopMovement(); return end
        
        orbitAngle = orbitAngle + (orbitSpeed * deltaTime)
        local offset = Vector3.new(math.cos(orbitAngle) * orbitRadius, 0, math.sin(orbitAngle) * orbitRadius)
        local orbitPos = targetPos + offset
        
        local distToTarget = (hrp.Position - targetPos).Magnitude
        local moveAlpha = math.clamp((approachSpeed * deltaTime) / (hrp.Position - orbitPos).Magnitude, 0, 1)
        hrp.CFrame = hrp.CFrame:Lerp(CFrame.new(orbitPos, targetPos), moveAlpha)
        
        if distToTarget <= (orbitRadius + 2) then
            if Hunt.State == "FLYING" then
                if Hunt.Type == "PET" then Hunt.InitialMoney = getCurrentMoney() end
                Hunt.State = "BUYING"
                Hunt.GraceTimer = os.clock() + 5
            end
            
            if fireproximityprompt then 
                fireproximityprompt(targetObj, 1, true) 
            end
        end
    end)
end

