local function getGardenSpawnPoint()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if plotId then
        local gardensFolder = workspace:FindFirstChild("Gardens")
        if gardensFolder then
            local myPlot = gardensFolder:FindFirstChild("Plot" .. tostring(plotId))
            if myPlot then return myPlot:FindFirstChild("SpawnPoint") end
        end
    end
    return nil
end

local function getPromptLocation(prompt)
    if not prompt or not prompt.Parent then return nil, nil end
    if prompt.Parent:IsA("BasePart") then return prompt.Parent.Position, prompt.Parent.CFrame
    elseif prompt.Parent:IsA("Attachment") then return prompt.Parent.WorldPosition, prompt.Parent.WorldCFrame
    elseif prompt.Parent:IsA("Model") then return prompt.Parent:GetPivot().Position, prompt.Parent:GetPivot()
    else
        local part = prompt:FindFirstAncestorWhichIsA("BasePart")
        if part then return part.Position, part.CFrame end
    end
    return nil, nil
end

local function getBestRoute(targetPos)
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return math.huge, nil end
    local currentPos = char.HumanoidRootPart.Position
    local bestDist = (currentPos - targetPos).Magnitude
    local bestRoute = nil
    
    local teleports = workspace:FindFirstChild("Teleports")
    if teleports then
        local sellTP = teleports:FindFirstChild("Sell")
        if sellTP and sellTP:IsA("BasePart") then local dist = (sellTP.Position - targetPos).Magnitude;
            if dist < bestDist then bestDist = dist; bestRoute = "Sell" end end
        local seedsTP = teleports:FindFirstChild("Seeds")
        if seedsTP and seedsTP:IsA("BasePart") then local dist = (seedsTP.Position - targetPos).Magnitude;
            if dist < bestDist then bestDist = dist; bestRoute = "Seeds" end end
    end
    
    local spawnPt = getGardenSpawnPoint()
    if spawnPt and spawnPt:IsA("BasePart") then
        local dist = (spawnPt.Position - targetPos).Magnitude;
        if dist < bestDist then bestDist = dist; bestRoute = "Garden" end
    end
    return bestDist, bestRoute 
end

local function getCurrentMoney()
    local sheckles = LocalPlayer:FindFirstChild("leaderstats") and LocalPlayer.leaderstats:FindFirstChild("Sheckles")
    return sheckles and sheckles.Value or 0
end

local noclipConnection = nil
local currentOrbitConnection = nil 

local function toggleNoclip(state)
    local char = LocalPlayer.Character
    if not char then return end
    if state then
        if not noclipConnection then noclipConnection = RunService.Stepped:Connect(function() for _, part in pairs(char:GetDescendants()) do if part:IsA("BasePart") and part.CanCollide then part.CanCollide = false end end end) end
    else
        if noclipConnection then noclipConnection:Disconnect();
            noclipConnection = nil end
    end
end

local function stopMovement()
    if currentOrbitConnection then currentOrbitConnection:Disconnect();
        currentOrbitConnection = nil end
    local char = LocalPlayer.Character
    if char then
        if char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.Anchored = false end
        if char:FindFirstChild("Humanoid") then char.Humanoid.WalkSpeed = 16;
            if char.PrimaryPart then char.Humanoid:MoveTo(char.PrimaryPart.Position) end end
    end
    toggleNoclip(false)
end

local function startSpamTP(targetObj)
    if currentOrbitConnection then return end 
    stopMovement() 
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    toggleNoclip(true) 
    
    currentOrbitConnection = RunService.Heartbeat:Connect(function()
        if not targetObj or not targetObj.Parent or not targetObj:IsDescendantOf(workspace) or not targetObj.Enabled then stopMovement(); Hunt.State = "IDLE"; Hunt.Target = nil; return end
        
        local targetPos, targetCFrame = getPromptLocation(targetObj)
        if not targetCFrame then stopMovement(); return end
        char:PivotTo(targetCFrame)
        if fireproximityprompt then fireproximityprompt(targetObj, 1, true) end
        if Hunt.State == "FLYING" then if Hunt.Type == "PET" then Hunt.InitialMoney = getCurrentMoney() end; Hunt.State = "BUYING";
            Hunt.GraceTimer = os.clock() + 10 end
    end)
end

local function startLinearFlight(targetObj)
    if currentOrbitConnection then return end 
    stopMovement() 
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local hrp = char.HumanoidRootPart
    local humanoid = char:FindFirstChild("Humanoid") 
    toggleNoclip(true)
    hrp.Anchored = true 
    
    currentOrbitConnection = RunService.Heartbeat:Connect(function(deltaTime)
        if not targetObj or not targetObj.Parent or not targetObj:IsDescendantOf(workspace) or not targetObj.Enabled 
            then stopMovement(); Hunt.State = "IDLE"; Hunt.Target = nil; return end
        local targetPos, _ = getPromptLocation(targetObj)
        if not targetPos then stopMovement(); return end
        local baseWalkSpeed = 16 
        if humanoid then baseWalkSpeed = humanoid.WalkSpeed end
        local bonusSpeed = tonumber(config.TweenSpeed) or 0 
        local finalApproachSpeed = baseWalkSpeed + bonusSpeed
        local currentPos = hrp.Position
 
        local distToTarget = (currentPos - targetPos).Magnitude
        if distToTarget > 5 then
            local moveDist = finalApproachSpeed * deltaTime
            local moveAlpha = math.clamp(moveDist / distToTarget, 0, 1)
            local nextPos = currentPos:Lerp(targetPos, moveAlpha)
            hrp.CFrame = CFrame.new(nextPos)
        else
            if Hunt.State == "FLYING" then if Hunt.Type == "PET" then Hunt.InitialMoney = getCurrentMoney() end;
                Hunt.State = "BUYING"; Hunt.GraceTimer = os.clock() + 5 end
        end
        if distToTarget <= 15 then if fireproximityprompt then fireproximityprompt(targetObj, 1, true) end end
    end)
end

