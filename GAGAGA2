    local function closestTopPointOnPart(part, worldPos)
        local localPos = part.CFrame:PointToObjectSpace(worldPos)
        local x = math.clamp(localPos.X, -part.Size.X / 2, part.Size.X / 2)
        local z = math.clamp(localPos.Z, -part.Size.Z / 2, part.Size.Z / 2)
        local y = part.Size.Y / 2
        return part.CFrame:PointToWorldSpace(Vector3.new(x, y, z))
    end

    local function getSprinklerPlacePosition(myPlot, plantPos, offsetIndex)
        local offset = SprinklerOffsets[offsetIndex] or SprinklerOffsets[1]
        local desired = plantPos + offset
        local parts = getPlantAreaParts(myPlot)

        local bestPos = nil
        local bestDist = math.huge

        for _, part in pairs(parts) do
            local pos = closestTopPointOnPart(part, desired)
            local dist = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(desired.X, 0, desired.Z)).Magnitude
            if dist < bestDist then
                bestDist = dist
                bestPos = pos
            end
        end

        if bestPos then return bestPos end
        return Vector3.new(desired.X, 142.602, desired.Z)
    end

    local function isTooCloseToSprinkler(myPlot, pos)
        for _, obj in pairs(myPlot:GetDescendants()) do
            if obj:IsA("Model") and SprinklerTypeSet[obj.Name] and obj.PrimaryPart then
                if (obj.PrimaryPart.Position - pos).Magnitude < 1 then return true end
            end
        end
        return false
    end

    local function findOneTargetPlant(plantsFolder)
        for _, plant in pairs(plantsFolder:GetChildren()) do
            local seedName = plant:GetAttribute("SeedName")
            if seedName and ToolsConfig.Targets[seedName] then
                local pos = getPlantPosition(plant)
                if pos then return plant, seedName, pos end
            end
        end
        return nil, nil, nil
    end

    local function doWateringCycle()
        if not Networking.WateringCan or not Networking.WateringCan.UseWateringCan then return end
        local tool = getToolByType("WateringCan", ToolsConfig.WaterCanType)
        if not tool then return end
        local equipped = equipTool(tool)
        if not equipped then return end
        local canName = equipped:GetAttribute("WateringCan") or ToolsConfig.WaterCanType
        local plantsFolder = getPlantsFolder()
        if not plantsFolder then return end

        for _, plant in pairs(plantsFolder:GetChildren()) do
            if not ToolsConfig.AutoWater then break end
            local seedName = plant:GetAttribute("SeedName")
            if seedName and ToolsConfig.Targets[seedName] then
                local pos = getPlantPosition(plant)
                if pos then
                    pcall(function()
                        Networking.WateringCan.UseWateringCan:Fire(pos - Vector3.new(0, 0.3, 0), canName, equipped)
                    end)
                    task.wait(0.05)
                end
            end
        end
    end

    local function placeOneSprinkler(sprinklerType, offsetIndex, myPlot, plotId, seedName, plantPos)
        local tool = getToolByType("Sprinkler", sprinklerType)
        if not tool then return false, "NO_TOOL" end

        local equipped = equipTool(tool)
        if not equipped then return false, "EQUIP_FAILED" end

        local sprinklerName = equipped:GetAttribute("Sprinkler") or sprinklerType
        local placePos = getSprinklerPlacePosition(myPlot, plantPos, offsetIndex)

        if isTooCloseToSprinkler(myPlot, placePos) then return false, "TOO_CLOSE" end

        local ok = pcall(function()
            Networking.Place.PlaceSprinkler:Fire(placePos, sprinklerName, equipped, plotId)
        end)

        if ok then
            task.wait(0.25)
            return true, "PLACED"
        end

        return false, "FIRE_FAILED"
    end

    local function doSprinklerCycle()
        if not Networking.Place or not Networking.Place.PlaceSprinkler then return end
        local myPlot, plotId = getMyPlot()
        if not myPlot or not plotId then return end
        local plantsFolder = myPlot:FindFirstChild("Plants")
        if not plantsFolder then return end
        local plant, seedName, plantPos = findOneTargetPlant(plantsFolder)
        if not plant then return end

        if ToolsConfig.SprinklerType == "ALL SPRINKLER" then
            local foundAnyTool = false
            for i, sprinklerType in ipairs(RealSprinklerTypes) do
                if not ToolsConfig.AutoSprinkler then break end
                local tool = getToolByType("Sprinkler", sprinklerType)
                if tool then
                    foundAnyTool = true
                    placeOneSprinkler(sprinklerType, i, myPlot, plotId, seedName, plantPos)
                end
                task.wait(0.1)
            end
            if not foundAnyTool then
                ToolsConfig.AutoSprinkler = false
                refreshFarmToggles()
                SaveToolsConfig()
            end
            return
        end

        local placed, reason = placeOneSprinkler(ToolsConfig.SprinklerType, 1, myPlot, plotId, seedName, plantPos)
        if reason == "NO_TOOL" or reason == "EQUIP_FAILED" then
            ToolsConfig.AutoSprinkler = false
            refreshFarmToggles()
            SaveToolsConfig()
        end
    end

    --// FRUIT PRICE
    local function normalizeText(s)
        s = tostring(s or "")
        s = s:gsub("^%s+", ""):gsub("%s+$", "")
        return s
    end

    local function normalizeFruitName(name)
        name = normalizeText(name)
        name = name:gsub("%s+", " ")
        return name
    end

    local function parseKgFromText(text)
        text = tostring(text or "")
        local num = text:match("([%d%.]+)%s*kg")
        if num then return tonumber(num) end
        num = text:match("%[([%d%.]+)%s*kg%]")
        if num then return tonumber(num) end
        return nil
    end

    local function parseFruitNameFromItem(item)
        local fruitName = item:GetAttribute("FruitName") or item:GetAttribute("Fruit")
        if fruitName then return normalizeFruitName(fruitName) end
        local name = tostring(item.Name or "")
        name = name:gsub("%s*%b[]", "")
        return normalizeFruitName(name)
    end

    local function parseKgFromItem(item)
        local weight = item:GetAttribute("Weight") or item:GetAttribute("Kg") or item:GetAttribute("KG") or item:GetAttribute("Mass")
        if tonumber(weight) then return tonumber(weight) end
        return parseKgFromText(item.Name)
    end

    local function getBackpackGrid()
        local backpackGui = PlayerGui:FindFirstChild("BackpackGui")
        if not backpackGui then return nil end
        local backpack = backpackGui:FindFirstChild("Backpack")
        if not backpack then return nil end
        local inventory = backpack:FindFirstChild("Inventory")
        if not inventory then return nil end
        local scrollingFrame = inventory:FindFirstChild("ScrollingFrame")
        if not scrollingFrame then return nil end
        return scrollingFrame:FindFirstChild("UIGridFrame")
    end

    local function isTextObj(obj)
        return obj and (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox"))
    end

    local function getSlotInfo(slot)
        if not slot:IsA("GuiObject") then return nil end
        local toolName = slot:FindFirstChild("ToolName")
        local toolCount = slot:FindFirstChild("ToolCount")
        if not isTextObj(toolName) or not isTextObj(toolCount) then return nil end
        local fruitName = normalizeFruitName(toolName.Text)
        local kg = parseKgFromText(toolCount.Text)
        if fruitName == "" or not kg then return nil end
        return {Slot = slot, FruitName = fruitName, Kg = kg}
    end

    local function ensurePriceLabel(slot)
        local label = slot:FindFirstChild(ToolsConfig.FruitPriceTextName)
        if label and label:IsA("TextLabel") then return label end

        label = Instance.new("TextLabel")
        label.Name = ToolsConfig.FruitPriceTextName
        label.BackgroundTransparency = 1
        label.BorderSizePixel = 0
        label.Size = UDim2.new(1, 0, 0, 16)
        label.Position = UDim2.new(0, 0, 0, -1)
        label.ZIndex = 100
        label.Text = ""
        label.TextColor3 = Color3.fromRGB(0, 255, 80)
        label.TextStrokeTransparency = 0
        label.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
        label.Font = Enum.Font.GothamBold
        label.TextSize = 11
        label.TextXAlignment = Enum.TextXAlignment.Center
        label.TextYAlignment = Enum.TextYAlignment.Center
        label.Parent = slot
        return label
    end

    local function isFruitItem(item)
        if not (item:IsA("Tool") or item:IsA("Configuration")) then return false end
        if not item:GetAttribute("Id") then return false end
        local fruitName = item:GetAttribute("FruitName") or item:GetAttribute("Fruit")
        local weight = item:GetAttribute("Weight")
        local mutation = item:GetAttribute("Mutation")
        local harvested = item:GetAttribute("HarvestedFruit")
        if harvested == true then return true end
        if fruitName and weight then return true end
        if fruitName and mutation and parseKgFromText(item.Name) then return true end
        if string.find(string.lower(item.Name), "kg") and fruitName then return true end
        return false
    end

    local function getAllFruitItems()
        local items = {}
        local function scan(container)
            if not container then return end
            for _, item in pairs(container:GetChildren()) do
                if isFruitItem(item) then
                    table.insert(items, {
                        Id = item:GetAttribute("Id"),
                        FruitName = parseFruitNameFromItem(item),
                        Kg = parseKgFromItem(item),
                        Used = false
                    })
                end
            end
        end
        scan(LocalPlayer:FindFirstChild("Backpack"))
        scan(LocalPlayer.Character)
        return items
    end

    local function getFruitPrice(fruitId)
        if not fruitId then return nil end
        local cached = priceCache[fruitId]
        if cached and os.clock() - cached.Time < 10 then return cached.Price end
        local ok, result = pcall(function()
            return Networking.NPCS.GetFruitBid:Fire(fruitId)
        end)
        if ok and type(result) == "table" and result.CurrentSellValue then
            local price = tonumber(result.CurrentSellValue)
            priceCache[fruitId] = {Price = price, Time = os.clock()}
            return price
        end
        return nil
    end

    local function buildFruitItemList()
        local result = {}
        for _, info in ipairs(getAllFruitItems()) do
            if info.Id and info.FruitName and info.FruitName ~= "" and info.Kg then
                local price = getFruitPrice(info.Id)
                if price then
                    info.Price = price
                    info.Used = false
                    table.insert(result, info)
                end
            end
            task.wait(0.01)
        end
        return result
    end

    local function findBestItemForSlot(slotInfo, itemList)
        local best = nil
        local bestDiff = math.huge
        for _, info in ipairs(itemList) do
            if not info.Used and info.FruitName == slotInfo.FruitName and info.Kg then
                local diff = math.abs(info.Kg - slotInfo.Kg)
                if diff < bestDiff then
                    best = info
                    bestDiff = diff
                end
            end
        end
        if best and bestDiff <= ToolsConfig.KgTolerance then
            best.Used = true
            return best
        end
        return nil
    end

    local function collectSlots(grid)
        local slots = {}
        for _, slot in pairs(grid:GetChildren()) do
            local info = getSlotInfo(slot)
            if info then table.insert(slots, info) end
        end
        table.sort(slots, function(a, b)
            local aNum = tonumber(a.Slot.Name) or 0
            local bNum = tonumber(b.Slot.Name) or 0
            return aNum < bNum
        end)
        return slots
    end

    local function applyPricesToGui()
        local grid = getBackpackGrid()
        if not grid then return end
        local itemList = buildFruitItemList()
        for _, slotInfo in ipairs(collectSlots(grid)) do
            local label = ensurePriceLabel(slotInfo.Slot)
            local match = findBestItemForSlot(slotInfo, itemList)
            if match and match.Price then
                label.Text = formatMoney(match.Price)
                label.Visible = true
            else
                label.Text = ""
                label.Visible = false
            end
        end
    end

    --// AUCTION
    local function openAuctionUI()
        pcall(function()
            local GuiController = require(LocalPlayer.PlayerScripts.Controllers.GuiController)
            GuiController:Open("Auction", nil, { "HUD" })
        end)
    end

    local function isAuctionOpen()
        local auctionGui = PlayerGui:FindFirstChild("Auction")
        return auctionGui and auctionGui:IsA("ScreenGui") and auctionGui.Enabled == true
    end

    local function startAuctionMonitor()
        if auctionCheckTask then return end
        auctionCheckTask = task.spawn(function()
            while HubGui.Parent do
                if not isAnyAuctionEnabled() then break end
                task.wait(5)
                if isAnyAuctionEnabled() and not isAuctionOpen() then
                    openAuctionUI()
                    task.wait(0.5)
                end
            end
            auctionCheckTask = nil
        end)
    end

    local function doAuctionLoop()
        if not isAnyAuctionEnabled() then return end
        if not isAuctionOpen() then
            startAuctionMonitor()
            return
        end

        local auctionUI = PlayerGui:FindFirstChild("Auction")
        if not auctionUI or not auctionUI.Enabled then return end
        local auctionFrame = auctionUI:FindFirstChild("Frame")
        if not auctionFrame then return end
        local scrollFrame = auctionFrame:FindFirstChild("ScrollingFrame")
        if not scrollFrame then return end

        for _, lot in pairs(scrollFrame:GetChildren()) do
            if lot:IsA("Frame") and lot.Name:match("^Lot_") then
                local lotId = lot.Name:match("Lot_(.+)")
                if not lotId then continue end
                if lastBuyLot[lotId] and os.clock() - lastBuyLot[lotId] < 1.5 then continue end

                local mainFrame = lot:FindFirstChild("Main_Frame", true)
                if not mainFrame then continue end

                local itemNameObj = mainFrame:FindFirstChild("ItemName", true)
                if not itemNameObj then continue end

                local itemNameLabel = itemNameObj:FindFirstChild("TextLabel")
                if not itemNameLabel then continue end

                local currentName = string.lower(itemNameLabel.Text)
                local matchItem = nil

                for itemKey in pairs(ToolsConfig.AuctionItems) do
                    if currentName:find(itemKey, 1, true) then
                        matchItem = itemKey
                        break
                    end
                end

                if not matchItem then continue end
                local itemSettings = ToolsConfig.AuctionItems[matchItem]
                if not itemSettings or not itemSettings.TimeEnabled then continue end

                local refreshObj = mainFrame:FindFirstChild("Refresh", true)
                local timerObj = nil
                if refreshObj then timerObj = refreshObj:FindFirstChild("Timer") end
                if not timerObj then timerObj = mainFrame:FindFirstChild("Timer", true) end

                local wkt = parseWaktu(timerObj and timerObj.Text)
                if wkt > itemSettings.TimeLimit then continue end

                local buyBtn = mainFrame:FindFirstChild("BuyButton", true)
                if not buyBtn then continue end
                local priceObj = buyBtn:FindFirstChild("Text")
                if not priceObj then continue end
                local priceLabel = priceObj:FindFirstChild("TextLabel")
                if not priceLabel then continue end

                local hrg = parseHarga(priceLabel.Text)
                pcall(function()
                    Networking.Auctioneer.PurchaseLot:Fire(lotId, hrg)
                end)

                lastBuyLot[lotId] = os.clock()
                task.wait(0.3)
            end
        end
    end

    task.spawn(function()
        print("[TOOLS V2] Loaded")

        if isAnyAuctionEnabled() then
            task.wait(0.5)
            openAuctionUI()
            startAuctionMonitor()
        end

        while HubGui.Parent do
            local now = os.clock()

            if ToolsConfig.AutoWater and now >= nextWaterTime then
                local interval = tonumber(ToolsConfig.WaterInterval) or 10
                nextWaterTime = now + math.max(interval, 0.5)
                task.spawn(function()
                    runWithToolLock("WateringCycle", doWateringCycle)
                end)
            end

            if ToolsConfig.AutoSprinkler and now >= nextSprinklerTime then
                local interval = tonumber(ToolsConfig.SprinklerInterval) or 120
                nextSprinklerTime = now + math.max(interval, 1)
                task.spawn(function()
                    runWithToolLock("SprinklerCycle", doSprinklerCycle)
                end)
            end

            if ToolsConfig.FruitPriceEnabled and now >= nextFruitPriceTime then
                local interval = tonumber(ToolsConfig.FruitPriceRefresh) or 3
                nextFruitPriceTime = now + math.max(interval, 1)
                task.spawn(applyPricesToGui)
            end

            if isAnyAuctionEnabled() then
                startAuctionMonitor()
                doAuctionLoop()
            end

            task.wait(0.1)
        end
    end)
end)
