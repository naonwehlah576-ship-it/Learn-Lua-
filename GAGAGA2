-- Anchor Auto Harvest: pakai 1 Moon Bloom di plot sendiri, bukan SpawnPoint luar garden.
local CachedAutoHarvestMoonBloom = nil

local function getMyPlotFolder()
    local plotId = LocalPlayer:GetAttribute("PlotId")
    if not plotId then return nil end

    local gardensFolder = workspace:FindFirstChild("Gardens")
    return gardensFolder and gardensFolder:FindFirstChild("Plot" .. tostring(plotId))
end

local function getMyPlantsFolder()
    local myPlot = getMyPlotFolder()
    return myPlot and myPlot:FindFirstChild("Plants")
end

local function isPositionInsideMyPlot(pos)
    local myPlot = getMyPlotFolder()
    if not myPlot then return true end -- kalau plot belum kebaca, jangan asal TP spam

    local ok, boxCf, boxSize = pcall(function()
        return myPlot:GetBoundingBox()
    end)

    if not ok or not boxCf or not boxSize then
        return true
    end

    local localPos = boxCf:PointToObjectSpace(pos)
    local margin = 2

    return math.abs(localPos.X) <= (boxSize.X / 2 + margin)
        and math.abs(localPos.Z) <= (boxSize.Z / 2 + margin)
end

local function getAutoHarvestMoonBloomAnchor()
    local plantsFolder = getMyPlantsFolder()
    if not plantsFolder then
        CachedAutoHarvestMoonBloom = nil
        return nil
    end

    if CachedAutoHarvestMoonBloom and CachedAutoHarvestMoonBloom.Parent == plantsFolder then
        return CachedAutoHarvestMoonBloom
    end

    CachedAutoHarvestMoonBloom = nil

    for _, plant in ipairs(plantsFolder:GetChildren()) do
        if plant:IsA("Model") then
            local seedName = plant:GetAttribute("SeedName")
            if seedName == "Moon Bloom" or plant.Name == "Moon Bloom" then
                CachedAutoHarvestMoonBloom = plant
