    while task.wait(0.2) do
        if not config.AutoBuyPet and not config.AutoClaimRare then
            if Hunt.State ~= "IDLE" then
                Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement()
            end
            continue
        end

        if Hunt.State == "IDLE" then
            if config.AutoClaimRare then
                local rareTarget = scanForRare()
                if rareTarget then
                    Hunt.State = "FLYING"; Hunt.Target = rareTarget; Hunt.Type = "RARE"; continue
                end
            end
            
            if config.AutoBuyPet then
                local petTarget, priceNum = scanForPet()
                if petTarget then
                    Hunt.State = "FLYING"; Hunt.Target = petTarget; Hunt.Type = "PET"; Hunt.ExpectedPrice = priceNum; continue
                end
            end

        elseif Hunt.State == "FLYING" then
            -- FIX PENTING: Cek .Enabled
            if not Hunt.Target or not Hunt.Target.Parent or not Hunt.Target:IsDescendantOf(workspace) or not Hunt.Target.Enabled then
                Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement(); continue
            end
            
            if config.MoveMethod == "SpamTP" then
                startSpamTP(Hunt.Target)
                
            elseif config.MoveMethod == "Walk" then
                local targetPos, _ = getPromptLocation(Hunt.Target)
                if not targetPos then Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement(); continue end
                
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") and char:FindFirstChild("Humanoid") then
                    local dist = (char.HumanoidRootPart.Position - targetPos).Magnitude
                    if dist > 5 then
                        char.Humanoid.WalkSpeed = tonumber(config.WalkSpeed) or 40
                        char.Humanoid:MoveTo(targetPos)
                    else
                        stopMovement()
                        if Hunt.Type == "PET" then Hunt.InitialMoney = getCurrentMoney() end
                        Hunt.State = "BUYING"
                        Hunt.GraceTimer = os.clock() + 5
                    end
                end
                
            else
                startSpiralFlight(Hunt.Target)
            end

        elseif Hunt.State == "BUYING" then
            if config.MoveMethod == "Walk" and Hunt.Target and Hunt.Target:IsDescendantOf(workspace) and Hunt.Target.Enabled then
                if fireproximityprompt then fireproximityprompt(Hunt.Target, 1, true) end
            end

            -- FIX: State kembali IDLE kalau target dimatiin (Enabled = false)
            if Hunt.Target and not Hunt.Target.Enabled then
                Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement()
                continue
            end

            if Hunt.Type == "PET" then
                local currentMoney = getCurrentMoney()
                if currentMoney <= (Hunt.InitialMoney - Hunt.ExpectedPrice) then
                    Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement()
                elseif os.clock() > Hunt.GraceTimer then
                    Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement()
                end
            elseif Hunt.Type == "RARE" then
                if not Hunt.Target or not Hunt.Target.Parent or not Hunt.Target:IsDescendantOf(workspace) then
                    Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement()
                elseif os.clock() > Hunt.GraceTimer then
                    Hunt.State = "IDLE"; Hunt.Target = nil; stopMovement()
                end
            end
        end
    end
end)

