task.spawn(function()
    while task.wait(2) do
        if config.AutoHarvest then
            if Hunt.State == "IDLE" then
                local spawnPt = getGardenSpawnPoint()
                if spawnPt and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
                    local hrp = LocalPlayer.Character.HumanoidRootPart
                    if (hrp.Position - spawnPt.Position).Magnitude > 20 then
                        hrp.CFrame = spawnPt.CFrame + Vector3.new(0, 3, 0)
                        task.wait(0.5)
                    end
                end
            end
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.ActionText == "Harvest" then
                    if fireproximityprompt then task.spawn(fireproximityprompt, obj, 1, true) end
                end
            end
        end
    end
end)

task.spawn(function()
    while task.wait(1.5) do
        if config.AutoSell and Networking then
            pcall(function() if Networking.NPCS and Networking.NPCS.SellAll then if typeof(Networking.NPCS.SellAll) == "table" and Networking.NPCS.SellAll.Fire then Networking.NPCS.SellAll:Fire() elseif typeof(Networking.NPCS.SellAll) == "function" then Networking.NPCS.SellAll() end end end)
        end
    end
end)

task.spawn(function()
    while task.wait(1) do
        if config.AutoBuySeed and Networking then
            for seedName, isSelected in pairs(config.SelectedSeeds) do
                if isSelected and SeedShopUI and SeedShopUI:FindFirstChild(seedName) then pcall(function() Networking.SeedShop.PurchaseSeed:Fire(seedName, 1) end) end
            end
        end
        if config.AutoBuyGear and Networking then
            for gearName, isSelected in pairs(config.SelectedGears) do
                if isSelected and GearShopUI and GearShopUI:FindFirstChild(gearName) then pcall(function() Networking.GearShop.PurchaseGear:Fire(gearName) end) end
            end
        end
    end
end)
