local function formatPrice(n)
    if n >= 1e9 then return string.format("%.2fB", n/1e9)
    elseif n >= 1e6 then return string.format("%.2fM", n/1e6)
    elseif n >= 1e3 then return string.format("%.1fK", n/1e3)
    else return tostring(math.floor(n)) end
end

local function buildLookup()
    local lookup = {}
    local bp = LocalPlayer:FindFirstChild("Backpack")
    if not bp then return lookup end
    for _, item in ipairs(bp:GetChildren()) do
        if item.ClassName == "Configuration" then
            local fn = item:GetAttribute("FruitName")
            if fn then
                if not lookup[fn] then lookup[fn] = {} end
                table.insert(lookup[fn], item)
            end
        end
    end
    return lookup
end

local function injectPrices()
    local grid = LocalPlayer.PlayerGui:FindFirstChild("BackpackGui", true)
    if not grid then return end
    grid = grid:FindFirstChild("UIGridFrame", true)
    if not grid then return end

    local lookup = buildLookup()
    local usedLookup = {}
    for k, v in pairs(lookup) do usedLookup[k] = {table.unpack(v)} end

    for _, slot in ipairs(grid:GetChildren()) do
        if not (slot:IsA("Frame") or slot:IsA("TextButton") or slot:IsA("ImageButton")) then continue end
        local toolNameLabel = slot:FindFirstChild("ToolName", true)
        if not toolNameLabel then continue end
        
        local fruitName = toolNameLabel.Text
        if not fruitName or fruitName == "" then continue end
        if slot:FindFirstChild("_PriceTag") then continue end

        local configs = usedLookup[fruitName]
        local fruitId = nil
        if configs and #configs > 0 then
            fruitId = configs[1]:GetAttribute("Id")
            table.remove(configs, 1)
        end

        local priceText = nil
        if fruitId and Networking and Networking.NPCS and Networking.NPCS.GetFruitBid then
            local ok, result = pcall(function() return Networking.NPCS.GetFruitBid:Fire(fruitId) end)
            if ok and result then
                local price = result.CurrentSellValue or result.CurrentOffer or result.BidPrice or 0
                priceText = formatPrice(price)
            end
        end

        if not priceText then continue end

        local tag = Instance.new("TextLabel")
        tag.Name = "_PriceTag"
        tag.Size = UDim2.new(1, 0, 0, 14)
        tag.Position = UDim2.new(0, 0, 1, -14)
        tag.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
        tag.BackgroundTransparency = 0.3
        tag.TextColor3 = Color3.fromRGB(100, 255, 100)
        tag.Text = priceText
        tag.Font = Enum.Font.GothamBold
        tag.TextSize = 11
        tag.ZIndex = (slot.ZIndex or 1) + 1
        tag.Parent = slot
        Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 3)
    end
end

local function clearPrices()
    local grid = LocalPlayer.PlayerGui:FindFirstChild("BackpackGui", true)
    if not grid then return end
    grid = grid:FindFirstChild("UIGridFrame", true)
    if not grid then return end
    for _, slot in ipairs(grid:GetChildren()) do
        local tag = slot:FindFirstChild("_PriceTag")
        if tag then tag:Destroy() end
    end
end

