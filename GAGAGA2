local function normalizePetSize(sizeValue)
    local s = tostring(sizeValue or "")
    if s == "" or s == "nil" then return "Normal" end
    s = s:gsub("%s+", "")
    if string.lower(s) == "big" then return "Big" end
    if string.lower(s) == "huge" then return "Huge" end
    return "Normal"
end

local function normalizePetType(typeValue)
    local s = tostring(typeValue or "")
    if string.lower(s) == "rainbow" then return "Rainbow" end
    return "Normal"
end

local function petVariantAllowed(petName, sizeValue, typeValue)
    if not config.SelectedPets[petName] then return false end

    local sizeName = normalizePetSize(sizeValue)
    local typeName = normalizePetType(typeValue)

    local sizeFilters = config.PetSizeFilters and config.PetSizeFilters[petName]
    local typeFilters = config.PetTypeFilters and config.PetTypeFilters[petName]

    if type(sizeFilters) == "table" and sizeFilters[sizeName] == false then
        return false
    end

    if type(typeFilters) == "table" and typeFilters[typeName] == false then
        return false
    end

    return true
end

local function getWildPetRefFolder()
    local map = workspace:FindFirstChild("Map")
    return map and map:FindFirstChild("WildPetRef")
end

local function findWildPetPromptForRef(refPart)
    if not (refPart and refPart:IsA("BasePart")) then return nil end

    local map = workspace:FindFirstChild("Map")
    local spawns = map and map:FindFirstChild("WildPetSpawns")
    local petName = refPart:GetAttribute("PetName")

    if spawns and petName then
        local visualName = "WildPet_" .. tostring(petName) .. "_" .. tostring(refPart.Name)
        local visual = spawns:FindFirstChild(visualName)

        if visual then
            local prompt = visual:FindFirstChild("BuyPrompt", true)
            if prompt and prompt:IsA("ProximityPrompt") and prompt.Enabled then
                return prompt
            end
        end
    end

    local bestPrompt = nil
    local bestDist = 12
    if spawns then
        for _, d in ipairs(spawns:GetDescendants()) do
            if d:IsA("ProximityPrompt") and d.Enabled and d.ActionText == "Buy" then
                local pos = nil
                if d.Parent and d.Parent:IsA("BasePart") then
                    pos = d.Parent.Position
                end
                if pos then
                    local dist = (pos - refPart.Position).Magnitude
                    if dist < bestDist then
                        bestDist = dist
                        bestPrompt = d
                    end
                end
            end
        end
    end

    return bestPrompt
end

local function scanForPet()
    local bestTarget = nil
    local bestPrice = 0
    local minDistance = math.huge

    local wildPetRef = getWildPetRefFolder()
    if not wildPetRef then
        return nil, 0
    end

    for _, refPart in ipairs(wildPetRef:GetChildren()) do
        if refPart:IsA("BasePart") then
            local petName = refPart:GetAttribute("PetName")
            local ownerUserId = refPart:GetAttribute("OwnerUserId")

            if type(petName) == "string" and PetData[petName] and ownerUserId ~= LocalPlayer.UserId then
                local petSize = refPart:GetAttribute("PetSize")
                local petType = refPart:GetAttribute("PetType")

                if petVariantAllowed(petName, petSize, petType) then
                    local targetPrompt = findWildPetPromptForRef(refPart)
                    if targetPrompt then
                        local tPos, _ = getPromptLocation(targetPrompt)
                        if tPos then
                            local effDist, _ = getBestRoute(tPos)
                            if effDist < minDistance then
                                minDistance = effDist
                                bestTarget = targetPrompt
                                bestPrice = refPart:GetAttribute("Price") or PetData[petName].PriceNum
                            end
                        end
                    end
                end
            end
        end
    end

    return bestTarget, bestPrice
end

