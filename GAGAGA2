local function updateScale()
    local camera = workspace.CurrentCamera
    if not camera then return end

    local viewport = camera.ViewportSize

    -- Dynamic scale supaya GUI tidak kegedean di emulator / layar kecil.
    local scaleX = viewport.X / 2100
    local scaleY = viewport.Y / 1180

    local scale = math.min(scaleX, scaleY)
    scale = math.clamp(scale, 0.5, 0.95)

    uiScale.Scale = scale
end
