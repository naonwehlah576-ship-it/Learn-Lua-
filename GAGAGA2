task.spawn(function()
    while task.wait(0.2) do
        if not config.AutoBuyPet and not config.AutoClaimRare then
            if Hunt.State ~= "IDLE" then
                Hunt.State = "IDLE"; Hunt.Target = nil; stopTween()
            end
            continue
        end

        if Hunt.State == "IDLE" then
            if config.AutoClaimRare then
                local rareTarget = scanForRare()
                if rareTarget then
                    Hunt.State = "FLYING"; Hunt.Target = rareTarget; Hunt.Type = "RARE"; continue
                end
            end
            
            if config.AutoBuyPet then
                local petTarget, priceNum = scanForPet()
                if petTarget then
                    Hunt.State = "FLYING"; Hunt.Target = petTarget; Hunt.Type = "PET"; Hunt.ExpectedPrice = priceNum; continue
                end
            end

        elseif Hunt.State == "FLYING" then
            if not Hunt.Target or not Hunt.Target.Parent or not Hunt.Target:IsDescendantOf(workspace) then
                Hunt.State = "IDLE"; Hunt.Target = nil; stopTween(); continue
            end
            
            local targetPos, targetCFrame = getPromptLocation(Hunt.Target)
            if not targetPos then
                Hunt.State = "IDLE"; Hunt.Target = nil; stopTween(); continue
            end

            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                local dist = (char.HumanoidRootPart.Position - targetPos).Magnitude
                if dist > 5 then
                    -- Eksekusi pergerakan (Tween atau TP)
                    moveToLocation(targetCFrame)
                else
                    stopTween()
                    if Hunt.Type == "PET" then Hunt.InitialMoney = getCurrentMoney() end
                    Hunt.State = "BUYING"
                    Hunt.GraceTimer = os.clock() + 5
                end
            end

        elseif Hunt.State == "BUYING" then
            -- SISTEM SPAM FIREPROXIMITYPROMPT
            if Hunt.Target and Hunt.Target:IsDescendantOf(workspace) then
                if fireproximityprompt then fireproximityprompt(Hunt.Target, 1, true) end
            end

            if Hunt.Type == "PET" then
                local currentMoney = getCurrentMoney()
                if currentMoney <= (Hunt.InitialMoney - Hunt.ExpectedPrice) then
                    Hunt.State = "IDLE"; Hunt.Target = nil
                elseif os.clock() > Hunt.GraceTimer then
                    Hunt.State = "IDLE"; Hunt.Target = nil
                end
            elseif Hunt.Type == "RARE" then
                if not Hunt.Target or not Hunt.Target.Parent or not Hunt.Target:IsDescendantOf(workspace) then
                    Hunt.State = "IDLE"; Hunt.Target = nil
                elseif os.clock() > Hunt.GraceTimer then
                    Hunt.State = "IDLE"; Hunt.Target = nil
                end
            end
        end
    end
end)

