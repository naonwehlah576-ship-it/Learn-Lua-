    local function tpToPlantTarget(pos)
        if not ToolsConfig.TpToTarget then return end
        if not pos then return end

        local char = LocalPlayer.Character
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not hrp then return end

        -- agak mundur/naik supaya nggak nyangkut di model tanaman.
        local targetPos = pos + Vector3.new(0, 4, 5)
        hrp.CFrame = CFrame.new(targetPos, pos)
        task.wait(0.12)
    end

    local function getPlantAreaParts(myPlot)
        local parts = {}
        for _, obj in pairs(myPlot:GetDescendants()) do
            if obj:IsA("BasePart") and CollectionService:HasTag(obj, "PlantArea") then
                table.insert(parts, obj)
            end
        end
        return parts
    end

    local function closestTopPointOnPart(part, worldPos)
        local localPos = part.CFrame:PointToObjectSpace(worldPos)
        local x = math.clamp(localPos.X, -part.Size.X / 2, part.Size.X / 2)
        local z = math.clamp(localPos.Z, -part.Size.Z / 2, part.Size.Z / 2)
        local y = part.Size.Y / 2
        return part.CFrame:PointToWorldSpace(Vector3.new(x, y, z))
    end

    local function getSprinklerPlacePosition(myPlot, plantPos, offsetIndex)
        local offset = SprinklerOffsets[offsetIndex] or SprinklerOffsets[1]
        local desired = plantPos + offset
        local parts = getPlantAreaParts(myPlot)

        local bestPos = nil
        local bestDist = math.huge

        for _, part in pairs(parts) do
            local pos = closestTopPointOnPart(part, desired)
            local dist = (Vector3.new(pos.X, 0, pos.Z) - Vector3.new(desired.X, 0, desired.Z)).Magnitude
            if dist < bestDist then
                bestDist = dist
                bestPos = pos
            end
        end

        if bestPos then return bestPos end
        return Vector3.new(desired.X, 142.602, desired.Z)
    end

    local function isTooCloseToSprinkler(myPlot, pos)
        for _, obj in pairs(myPlot:GetDescendants()) do
            if obj:IsA("Model") and SprinklerTypeSet[obj.Name] and obj.PrimaryPart then
                if (obj.PrimaryPart.Position - pos).Magnitude < 1 then return true end
            end
        end
        return false
    end

    local function findOneTargetPlant(plantsFolder)
        for _, plant in pairs(plantsFolder:GetChildren()) do
            local seedName = plant:GetAttribute("SeedName")
            if seedName and ToolsConfig.Targets[seedName] then
                local pos = getPlantPosition(plant)
                if pos then return plant, seedName, pos end
            end
        end
        return nil, nil, nil
    end

    local function doWateringCycle()
        if not Networking.WateringCan or not Networking.WateringCan.UseWateringCan then return end
        local tool = getToolByType("WateringCan", ToolsConfig.WaterCanType)
        if not tool then return end
        local equipped = equipTool(tool)
        if not equipped then return end
        local canName = equipped:GetAttribute("WateringCan") or ToolsConfig.WaterCanType
        local plantsFolder = getPlantsFolder()
        if not plantsFolder then return end

        for _, plant in pairs(plantsFolder:GetChildren()) do
            if not ToolsConfig.AutoWater then break end
            local seedName = plant:GetAttribute("SeedName")
            if seedName and ToolsConfig.Targets[seedName] then
                local pos = getPlantPosition(plant)
                if pos then
                    tpToPlantTarget(pos)
                    pcall(function()
                        Networking.WateringCan.UseWateringCan:Fire(pos - Vector3.new(0, 0.3, 0), canName, equipped)
                    end)
                    task.wait(0.05)
                end
            end
        end
    end

    local function placeOneSprinkler(sprinklerType, offsetIndex, myPlot, plotId, seedName, plantPos)
        local tool = getToolByType("Sprinkler", sprinklerType)
        if not tool then return false, "NO_TOOL" end

        local equipped = equipTool(tool)
        if not equipped then return false, "EQUIP_FAILED" end

        local sprinklerName = equipped:GetAttribute("Sprinkler") or sprinklerType
        local placePos = getSprinklerPlacePosition(myPlot, plantPos, offsetIndex)

        if isTooCloseToSprinkler(myPlot, placePos) then return false, "TOO_CLOSE" end

        tpToPlantTarget(plantPos)

        local ok = pcall(function()
            Networking.Place.PlaceSprinkler:Fire(placePos, sprinklerName, equipped, plotId)
        end)

        if ok then
            task.wait(0.25)
            return true, "PLACED"
        end

        return false, "FIRE_FAILED"
    end

    local function doSprinklerCycle()
        if not Networking.Place or not Networking.Place.PlaceSprinkler then return end
        local myPlot, plotId = getMyPlot()
        if not myPlot or not plotId then return end
        local plantsFolder = myPlot:FindFirstChild("Plants")
        if not plantsFolder then return end
        local plant, seedName, plantPos = findOneTargetPlant(plantsFolder)
        if not plant then return end

        if ToolsConfig.SprinklerType == "ALL SPRINKLER" then
            local foundAnyTool = false
            for i, sprinklerType in ipairs(RealSprinklerTypes) do
                if not ToolsConfig.AutoSprinkler then break end
                local tool = getToolByType("Sprinkler", sprinklerType)
                if tool then
                    foundAnyTool = true
                    placeOneSprinkler(sprinklerType, i, myPlot, plotId, seedName, plantPos)
                end
                task.wait(0.1)
            end
            if not foundAnyTool then
                ToolsConfig.AutoSprinkler = false
                refreshFarmToggles()
                SaveToolsConfig()
            end
            return
        end

        local placed, reason = placeOneSprinkler(ToolsConfig.SprinklerType, 1, myPlot, plotId, seedName, plantPos)
        if reason == "NO_TOOL" or reason == "EQUIP_FAILED" then
            ToolsConfig.AutoSprinkler = false
            refreshFarmToggles()
            SaveToolsConfig()
        end
    end

    --// FRUIT PRICE
    local function normalizeText(s)
        s = tostring(s or "")
        s = s:gsub("^%s+", ""):gsub("%s+$", "")
        return s
    end

    local function normalizeFruitName(name)
        name = normalizeText(name)
        name = name:gsub("%s+", " ")
        return name
    end

    local function parseKgFromText(text)
        text = tostring(text or "")
        local num = text:match("([%d%.]+)%s*kg")
        if num then return tonumber(num) end
        num = text:match("%[([%d%.]+)%s*kg%]")
        if num then return tonumber(num) end
        return nil
    end

    local function parseFruitNameFromItem(item)
        local fruitName = item:GetAttribute("FruitName") or item:GetAttribute("Fruit")
        if fruitName then return normalizeFruitName(fruitName) end
        local name = tostring(item.Name or "")
        name = name:gsub("%s*%b[]", "")
        return normalizeFruitName(name)
    end

    local function parseKgFromItem(item)
        local weight = item:GetAttribute("Weight") or item:GetAttribute("Kg") or item:GetAttribute("KG") or item:GetAttribute("Mass")
        if tonumber(weight) then return tonumber(weight) end
        return parseKgFromText(item.Name)
    end

    local function getBackpackGrid()
        local backpackGui = PlayerGui:FindFirstChild("BackpackGui")
        if not backpackGui then return nil end
        local backpack = backpackGui:FindFirstChild("Backpack")
