local function scanForRare()
    local bestTarget = nil;
    local minDistance = math.huge
    for _, obj in pairs(workspace:GetDescendants()) do
        if obj:IsA("ProximityPrompt") and obj.Enabled and obj.ActionText == "CLAIM" and (obj.ObjectText == "Gold Seed" or obj.ObjectText == "Rainbow Seed") then
            local tPos, _ = getPromptLocation(obj)
            if tPos then local effDist, _ = getBestRoute(tPos);
                if effDist < minDistance then minDistance = effDist; bestTarget = obj end end
        end
    end
    return bestTarget
end

local function scanForPet()
    local bestTarget = nil;
    local bestPrice = 0; local minDistance = math.huge
    for _, petName in ipairs(PetOrder) do
        if config.SelectedPets[petName] and PetData[petName] then
            local targetPriceStr = PetData[petName].PriceStr
            for _, obj in pairs(workspace:GetDescendants()) do
                if obj:IsA("ProximityPrompt") and obj.Enabled and obj.ActionText == "Buy" and obj.ObjectText == targetPriceStr then
                    local tPos, _ = getPromptLocation(obj)
                    if tPos then local effDist, _ = getBestRoute(tPos);
                        if effDist < minDistance then minDistance = effDist; bestTarget = obj;
                            bestPrice = PetData[petName].PriceNum end end
                end
            end
        end
    end
    return bestTarget, bestPrice
end

