    local function sendMailboxItem(itemName, category, amount)
        amount = tonumber(amount) or 0
        if amount <= 0 then
            warn("[MAIL] Amount harus > 0:", itemName)
            return false
        end

        local userId = getMailTargetUserId()
        if not userId then
            return false
        end

        local fixedCategory = fixMailCategory(category, itemName)
        local payload = {
            {
                Category = fixedCategory,
                ItemKey = itemName,
                Count = amount
            }
        }

        local ok, result = pcall(function()
            return Networking.Mailbox.SendBatch:Fire(userId, payload, "Sent via Dafa Hub")
        end)

        if ok and result then
            print("[MAIL] Sent:", amount, itemName, "to", mailTargetBox.Text)
            return true
        end

        warn("[MAIL] Failed:", itemName, tostring(result))
        return false
    end

