    local function refreshWeatherGui()
        if not ToolsConfig.WeatherPredictor then
            destroyWeatherGui()
            return
        end

        ensureWeatherGui()

        local cur = weatherAt(os.time())
        local nowLabel = weatherRows.NowLabel
        local phaseLabel = weatherRows.PhaseLabel

        if cur and cur.name then
            nowLabel.Text = string.format("Now: %s %s", WeatherIcon[cur.name] or "", cur.name)
            nowLabel.TextColor3 = WeatherColor[cur.name] or Color3.fromRGB(230, 230, 230)
            phaseLabel.Text = string.format("Next phase: %s", weatherClock(cur.secsLeft))
        else
            nowLabel.Text = "Now: Unknown / data expired"
            nowLabel.TextColor3 = Color3.fromRGB(255, 110, 110)
            phaseLabel.Text = "Need newer DATA.weather"
        end

        for _, name in ipairs(WeatherWatchOrder) do
            local nxt = nextWeatherByName(name, 2500)
            local row = weatherRows[name]

            if row then
                if cur and cur.name == name then
                    row.Text = string.format("%s %s: NOW (%s left)", WeatherIcon[name] or "•", name, weatherClock(cur.secsLeft))
                elseif nxt then
                    row.Text = string.format("%s %s: %s", WeatherIcon[name] or "•", name, weatherShortDur(nxt.secs))
                else
                    row.Text = string.format("%s %s: not in data", WeatherIcon[name] or "•", name)
                end
            end
        end
    end

    task.spawn(function()
        print("[TOOLS V2] Loaded")

        if isAnyAuctionEnabled() then
            task.wait(0.5)
            openAuctionUI()
            startAuctionMonitor()
        end

        while HubGui.Parent do
            local now = os.clock()

            if ToolsConfig.AutoWater and now >= nextWaterTime then
                local interval = tonumber(ToolsConfig.WaterInterval) or 10
                nextWaterTime = now + math.max(interval, 0.5)
                task.spawn(function()
                    runWithToolLock("WateringCycle", doWateringCycle)
                end)
            end

            if ToolsConfig.AutoSprinkler and now >= nextSprinklerTime then
                local interval = tonumber(ToolsConfig.SprinklerInterval) or 120
                nextSprinklerTime = now + math.max(interval, 1)
                task.spawn(function()
                    runWithToolLock("SprinklerCycle", doSprinklerCycle)
                end)
            end

            if ToolsConfig.FruitPriceEnabled and now >= nextFruitPriceTime then
                local interval = tonumber(ToolsConfig.FruitPriceRefresh) or 3
                nextFruitPriceTime = now + math.max(interval, 1)
                task.spawn(applyPricesToGui)
            end

            if ToolsConfig.WeatherPredictor then
                refreshWeatherGui()
            elseif weatherGui then
                destroyWeatherGui()
            end

            if isAnyAuctionEnabled() then
                startAuctionMonitor()
                doAuctionLoop()
            end

            task.wait(0.1)
        end
    end)
