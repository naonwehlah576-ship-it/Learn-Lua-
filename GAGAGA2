        local extracted = string.match(box.Text, "%-?%d+%.?%d*")
        local num = extracted and tonumber(extracted)
        if num then
            config[configKey] = tostring(num)
            box.Text = tostring(num)
        else
            box.Text = config[configKey]
        end
        saveConfig()
    end)
end

