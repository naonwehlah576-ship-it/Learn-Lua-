    local function isGiftableInventoryEntry(category, itemKey, entryValue, seenPets)
        if MailboxItemCatalog and MailboxItemCatalog.IsGiftable then
            local okGiftable, giftable = pcall(function()
                return MailboxItemCatalog.IsGiftable(category)
            end)

            if okGiftable and not giftable then
                return false
            end
        end

        if category == "HarvestedFruits" then
            return typeof(entryValue) == "table" and entryValue.Id ~= nil
        end

        if category == "Pets" then
            if typeof(entryValue) ~= "table" or entryValue.Id == nil then
                return false
            end

            if seenPets[itemKey] then
                return false
            end

            seenPets[itemKey] = true
            return entryValue.Equipped ~= true
        end

        return typeof(entryValue) == "number" and entryValue > 0
    end

    local function getMailboxDisplayName(category, itemKey, entryValue)
        if category == "HarvestedFruits" and typeof(entryValue) == "table" then
            local fruitName = entryValue.FruitName or entryValue.Fruit or entryValue.Name or entryValue.SeedName
            local mutation = entryValue.Mutation
            local weight = entryValue.Weight or entryValue.Kg or entryValue.Mass

            local text = fruitName and tostring(fruitName) or tostring(itemKey)

            if mutation and mutation ~= "" then
                text = text .. " [" .. tostring(mutation) .. "]"
            end

            if tonumber(weight) then
                text = text .. " [" .. string.format("%.2fkg", tonumber(weight)) .. "]"
            end

            return text
        end

        if category == "Pets" and typeof(entryValue) == "table" then
            return tostring(entryValue.Name or entryValue.PetName or entryValue.Type or itemKey)
        end

        return tostring(itemKey)
    end

    local function getGiftableMailboxEntries()
        local results = {}

        -- Cara asli game: PlayerStateClient.Data.Inventory + MailboxItemCatalog.Categories.
        -- Ini yang paling akurat karena sama seperti Mailbox UI resmi.
        if PlayerStateClient and MailboxItemCatalog and typeof(MailboxItemCatalog.Categories) == "table" then
            local replica = nil
            pcall(function()
                replica = PlayerStateClient:GetLocalReplica()
            end)

            local inventory = replica and replica.Data and replica.Data.Inventory

            if typeof(inventory) == "table" then
                local seenPets = {}

                for _, category in pairs(MailboxItemCatalog.Categories) do
                    local categoryData = inventory[category]

                    if typeof(categoryData) == "table" then
                        if category == "HarvestedFruits" or category == "Pets" then
                            for itemKey, entryValue in pairs(categoryData) do
                                if isGiftableInventoryEntry(category, itemKey, entryValue, seenPets) then
                                    table.insert(results, {
                                        Name = getMailboxDisplayName(category, itemKey, entryValue),
                                        ItemKey = itemKey,
                                        Category = category,
                                        Count = 1
                                    })
                                end
                            end
                        else
                            for itemKey, entryValue in pairs(categoryData) do
                                if isGiftableInventoryEntry(category, itemKey, entryValue, seenPets) then
                                    table.insert(results, {
                                        Name = tostring(itemKey),
                                        ItemKey = itemKey,
                                        Category = category,
                                        Count = entryValue
                                    })
                                end
                            end
                        end
                    end
                end

                table.sort(results, function(a, b)
                    if a.Category == b.Category then
                        return tostring(a.Name) < tostring(b.Name)
                    end
                    return tostring(a.Category) < tostring(b.Category)
                end)

                return results, "PlayerStateClient"
            end
        end

        -- Fallback MailPerfect lama: hanya Tool dengan MainCategory.
        -- Tidak pakai tebak nama Gear lagi biar tidak kebanyakan item yang sebenarnya tidak bisa mailbox.
        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if backpack then
            for _, item in pairs(backpack:GetChildren()) do
                if item:IsA("Tool") then
                    local category = item:GetAttribute("MainCategory")
                    local count = item:GetAttribute("Count") or 1

                    if category then
                        table.insert(results, {
                            Name = item.Name,
                            ItemKey = item.Name,
                            Category = category,
                            Count = count
                        })
                    end
                end
            end
        end

        return results, "BackpackFallback"
    end

