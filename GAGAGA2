    end

    local function isFruitItem(item)
        if not (item:IsA("Tool") or item:IsA("Configuration")) then return false end
        if not item:GetAttribute("Id") then return false end
        local fruitName = item:GetAttribute("FruitName") or item:GetAttribute("Fruit")
        local weight = item:GetAttribute("Weight")
        local mutation = item:GetAttribute("Mutation")
        local harvested = item:GetAttribute("HarvestedFruit")
        if harvested == true then return true end
        if fruitName and weight then return true end
        if fruitName and mutation and parseKgFromText(item.Name) then return true end
        if string.find(string.lower(item.Name), "kg") and fruitName then return true end
        return false
    end

    local function getAllFruitItems()
        local items = {}
        local function scan(container)
            if not container then return end
            for _, item in pairs(container:GetChildren()) do
                if isFruitItem(item) then
                    table.insert(items, {
                        Id = item:GetAttribute("Id"),
                        FruitName = parseFruitNameFromItem(item),
                        Kg = parseKgFromItem(item),
                        Used = false
                    })
                end
            end
        end
        scan(LocalPlayer:FindFirstChild("Backpack"))
        scan(LocalPlayer.Character)
        return items
    end

    local function getFruitPrice(fruitId)
        if not fruitId then return nil end
        local cached = priceCache[fruitId]
        if cached and os.clock() - cached.Time < 10 then return cached.Price end
        local ok, result = pcall(function()
            return Networking.NPCS.GetFruitBid:Fire(fruitId)
        end)
        if ok and type(result) == "table" and result.CurrentSellValue then
            local price = tonumber(result.CurrentSellValue)
            priceCache[fruitId] = {Price = price, Time = os.clock()}
            return price
        end
        return nil
    end

    local function buildFruitItemList()
        local result = {}
        for _, info in ipairs(getAllFruitItems()) do
            if info.Id and info.FruitName and info.FruitName ~= "" and info.Kg then
                local price = getFruitPrice(info.Id)
                if price then
                    info.Price = price
                    info.Used = false
                    table.insert(result, info)
                end
            end
            task.wait(0.01)
        end
        return result
    end

    local function findBestItemForSlot(slotInfo, itemList)
        local best = nil
        local bestDiff = math.huge
        for _, info in ipairs(itemList) do
            if not info.Used and info.FruitName == slotInfo.FruitName and info.Kg then
                local diff = math.abs(info.Kg - slotInfo.Kg)
                if diff < bestDiff then
                    best = info
                    bestDiff = diff
                end
            end
        end
        if best and bestDiff <= ToolsConfig.KgTolerance then
            best.Used = true
            return best
        end
        return nil
    end

    local function collectSlots(grid)
        local slots = {}
        for _, slot in pairs(grid:GetChildren()) do
            local info = getSlotInfo(slot)
            if info then table.insert(slots, info) end
        end
        table.sort(slots, function(a, b)
            local aNum = tonumber(a.Slot.Name) or 0
            local bNum = tonumber(b.Slot.Name) or 0
            return aNum < bNum
        end)
        return slots
    end

    local function applyPricesToGui()
        local grid = getBackpackGrid()
        if not grid then return end
        local itemList = buildFruitItemList()
        for _, slotInfo in ipairs(collectSlots(grid)) do
            local label = ensurePriceLabel(slotInfo.Slot)
            local match = findBestItemForSlot(slotInfo, itemList)
            if match and match.Price then
                label.Text = formatMoney(match.Price)
                label.Visible = true
            else
                label.Text = ""
                label.Visible = false
            end
        end
    end

