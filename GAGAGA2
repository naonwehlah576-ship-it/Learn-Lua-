local function populateHarvestTargets(scrollFrame, targetConfigTable, dataList)
    local masterState = 0
    local function applyUIState(btn, state)
        if state == 0 then btn.Text = "OFF";
            btn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
        elseif state == 1 then btn.Text = "ALL";
            btn.BackgroundColor3 = Color3.fromRGB(50, 200, 50)
        elseif state == 2 then btn.Text = "LIMIT";
            btn.BackgroundColor3 = Color3.fromRGB(220, 150, 20) end
    end

    local rowAll = Instance.new("Frame"); rowAll.Name = "_ToggleAll";
    rowAll.Size = UDim2.new(1, -6, 0, 26); rowAll.BackgroundTransparency = 1; rowAll.LayoutOrder = 0;
    rowAll.Parent = scrollFrame
    local btnAll = Instance.new("TextButton"); btnAll.Size = UDim2.new(0, 38, 0, 16);
    btnAll.Position = UDim2.new(0, 2, 0, 5); btnAll.BorderSizePixel = 0; btnAll.TextColor3 = Color3.fromRGB(255, 255, 255); btnAll.Font = Enum.Font.GothamBold; btnAll.TextSize = 9;
    btnAll.Parent = rowAll
    local btnCornerAll = Instance.new("UICorner"); btnCornerAll.CornerRadius = UDim.new(0, 3);
    btnCornerAll.Parent = btnAll
    local txtAll = Instance.new("TextLabel"); txtAll.Size = UDim2.new(1, -46, 1, 0);
    txtAll.Position = UDim2.new(0, 46, 0, 0); txtAll.BackgroundTransparency = 1; txtAll.Text = "-- TOGGLE ALL --"; txtAll.TextColor3 = Color3.fromRGB(255, 210, 50);
    txtAll.Font = Enum.Font.GothamBold; txtAll.TextSize = 11; txtAll.TextXAlignment = Enum.TextXAlignment.Left; txtAll.Parent = rowAll
    applyUIState(btnAll, masterState)

    btnAll.MouseButton1Click:Connect(function()
        masterState = (masterState + 1) % 3
        applyUIState(btnAll, masterState)
        for _, itemName in ipairs(dataList) do
            targetConfigTable[itemName] = masterState
            local childRow = scrollFrame:FindFirstChild(itemName)
            if childRow then
                local cBtn = childRow:FindFirstChildOfClass("TextButton")
                if cBtn then applyUIState(cBtn, masterState) end
                
                -- Toggle textbox visibility global
                local boxLim = childRow:FindFirstChild("BoxLimit")
                local boxBase = childRow:FindFirstChild("BoxBase")
                if boxLim and boxBase then
                    boxLim.Visible = (masterState == 2)
                    boxBase.Visible = (masterState == 2)
                end
            end
        end
        saveConfig()
    end)

    for i, itemName in ipairs(dataList) do
