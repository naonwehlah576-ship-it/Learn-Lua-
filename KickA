local function isValidBrainrot(obj)
    local basePrice = BASE_PRICE[obj.Name]
    if not basePrice then 
        autoScanIndex()
        basePrice = BASE_PRICE[obj.Name] or 0
    end
    local mutKey = obj:GetAttribute("Mutation") and tostring(obj:GetAttribute("Mutation")) or "None"
    local actualPrice = basePrice * (MULTIPLIER[mutKey] or 1)

    if PHANTOM_EVENT[obj.Name] and phantomEnabled[obj.Name] then return true end

    local ufoActive, baconActive, heavenlyActive = false, false, false
    pcall(function() ufoActive = (player.PlayerGui.TimersGui.TimedUpgrades.Alien.TimeLabel.Text ~= "00:00") end)
    pcall(function() baconActive = (player.PlayerGui.TimersGui.TimedUpgrades.Bacon.TimeLabel.Text ~= "00:00") end)
    pcall(function() heavenlyActive = (player.PlayerGui.TimersGui.TimedUpgrades.Heavenly.TimeLabel.Text ~= "00:00") end)

    if ufoActive or baconActive or heavenlyActive then return actualPrice >= getMinHarga() end

    -- TUMBAL HEAVENLY
    if autoHeavenlyRunning then
        for _, hName in ipairs(HEAVENLY_REQUIRED) do if obj.Name == hName then return true end end
    end

    -- TUMBAL BACON
    if autoBaconRunning then
        for _, reqName in ipairs(BACON_REQUIRED_LIST) do
            if obj.Name == reqName and countInBackpack(reqName) < getBaconStokTarget() then return true end
        end
    end

    -- TUMBAL UFO
    if autoUFORunning then
        for _, uName in ipairs(UFO_REQUIRED) do if obj.Name == uName then return true end end
    end
    
    return actualPrice >= getMinHarga()
end

