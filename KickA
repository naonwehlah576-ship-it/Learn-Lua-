local function isValidBrainrot(obj)
    local mutation = obj:GetAttribute("Mutation")
    local mutKey = mutation and tostring(mutation) or "None"
    local basePrice = BASE_PRICE[obj.Name]
    if not basePrice then return false end
    local multiplier = MULTIPLIER[mutKey] or 1
    local actualPrice = basePrice * multiplier

    -- PHANTOM EVENT (Bypass Mutlak)
    if PHANTOM_EVENT[obj.Name] and phantomEnabled[obj.Name] then return true end

    -- Cek status timer UI buat tau event lagi jalan atau nggak
    local ufoActive = false
    pcall(function() ufoActive = (player.PlayerGui.TimersGui.TimedUpgrades.Alien.TimeLabel.Text ~= "00:00") end)
    
    local baconActive = false
    pcall(function() baconActive = (player.PlayerGui.TimersGui.TimedUpgrades.Bacon.TimeLabel.Text ~= "00:00") end)

    -- KALAU EVENT LAGI JALAN: Fokus 100% ke Min Harga (M/s)
    if ufoActive or baconActive then
        return actualPrice >= getMinHarga()
    end

    -- TUMBAL BACON (Grup Kolektif)
    if autoBaconRunning then
        for _, reqName in ipairs(BACON_REQUIRED_LIST) do
            if obj.Name == reqName then
                if countInBackpack(reqName) < getBaconStokTarget() then
                    return true 
                end
            end
        end
    end

    -- TUMBAL UFO
    if autoUFORunning then
        for _, uName in ipairs(UFO_REQUIRED) do
            if obj.Name == uName then return true end
        end
    end
    
    -- Filter M/s Normal
    return actualPrice >= getMinHarga()
end

