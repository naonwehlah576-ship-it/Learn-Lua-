    return val
end

local function getMinFav()
    local val = tonumber(MinFavBox.Text)
    if not val or val <= 0 then return 4000000 end
    return val * 1000000
end

local function isValidBrainrot(obj)
    if BACON_EVENT[obj.Name] and baconEnabled[obj.Name] then return true end
    if UFO_EVENT[obj.Name] and ufoEnabled[obj.Name] then return true end
    local mutation = obj:GetAttribute("Mutation")
    local mutKey = mutation and tostring(mutation) or "None"
    local basePrice = BASE_PRICE[obj.Name]
    if not basePrice then return false end
    local multiplier = MULTIPLIER[mutKey] or 1
    local actualPrice = basePrice * multiplier
    return actualPrice >= getMinHarga()
end

