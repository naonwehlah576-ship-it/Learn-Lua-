local function syncPowerAndUI()
    local bExpired = isBaconExpired()
    local uExpired = isUFOExpired()

    -- [PERBAIKAN]: Kalau ada Event yang AKTIF, SEMUA AKUN IKUT! (Persetan sama Toggle)
    if not bExpired then
        KickPowerBox.Text = "1"
        KickArg2Box.Text = tostring(getMaxKickPower())
        setInfo("🥓 Bacon: Sedang Aktif! (Ikut Event)", Color3.fromRGB(255, 180, 50))
        currentTarget = "Bacon Event"
        return
    end
    if not uExpired then
        KickPowerBox.Text = "1"
        KickArg2Box.Text = tostring(getMaxKickPower())
        setInfo("🛸 UFO: Sedang Aktif! (Ikut Event)", Color3.fromRGB(100, 200, 255))
        currentTarget = "UFO Event"
        return
    end

    -- PRIORITAS 2 & 3: Kalau gak ada event jalan, baru cek Toggle buat nyari barang & ngaktifin
    if autoBaconRunning then
        if hasAllBaconBrainrots() then
            KickPowerBox.Text = "1"
            KickArg2Box.Text = tostring(getMaxKickPower())
            setInfo("🥓 Bacon: Ready, aktifasi...", Color3.fromRGB(255, 220, 50))
            currentTarget = "Aktifasi Bacon"
            tryActivateBacon()
            return
        end
        for _, name in ipairs(BACON_REQUIRED_LIST) do
            if not hasInBackpack(name) then
                local targetPower = BACON_KICK_POWER[name]
                if not targetPower or targetPower == 0 then targetPower = getMaxKickPower() end
                KickPowerBox.Text = "1"
                KickArg2Box.Text = tostring(targetPower)
                setInfo("🥓 Bacon: Cari " .. name, Color3.fromRGB(255, 150, 50))
                currentTarget = "Cari " .. name
                return
            end
        end
    end

    if autoUFORunning then
        if hasAllUFOBrainrots() then
            KickPowerBox.Text = "1"
            KickArg2Box.Text = tostring(getMaxKickPower())
            setInfo("🛸 UFO: Ready, aktifasi...", Color3.fromRGB(150, 220, 255))
            currentTarget = "Aktifasi UFO"
            tryActivateUFO()
            return
        end
        for _, name in ipairs(UFO_REQUIRED) do
            if not hasInBackpack(name) then
                local targetPower = UFO_KICK_POWER[name]
                if not targetPower or targetPower == 0 then targetPower = getMaxKickPower() end
                KickPowerBox.Text = "1"
                KickArg2Box.Text = tostring(targetPower)
                setInfo("🛸 UFO: Cari " .. name, Color3.fromRGB(100, 200, 255))
                currentTarget = "Cari " .. name
                return
            end
        end
    end

    setInfo("✅ Semua Target Komplit/Idle", Color3.fromRGB(150, 150, 150))
    currentTarget = "Farming Biasa"
end

local running = false
local KICK_POS = Vector3.new(704.0, 3.2, 237.6)
local SAFE_POS = Vector3.new(701.9, 4.2, 229.5)

-- ================== MAIN LOOP ==================
local function runLoop()
    while running do
        local char0 = player.Character
        local hum0 = char0 and char0:FindFirstChild("Humanoid")
        if not char0 or not hum0 or hum0.Health <= 0 then
            setStatus("Nunggu respawn...", Color3.fromRGB(255, 100, 50))
            repeat 
                task.wait(0.1) 
            until player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
            
            setStatus("Loading inventory...", Color3.fromRGB(255, 180, 50))
            task.wait(1.5)
        end

        syncPowerAndUI()

        setStatus("TP... [" .. currentTarget .. "]", Color3.fromRGB(100, 180, 255))
        local root = getRoot()
        if not root then task.wait(1) continue end
        pcall(function() root.CFrame = CFrame.new(KICK_POS) end)
        task.wait(0.5)

        if not running then break end

        setStatus("Nge-kick... [" .. currentTarget .. "]", Color3.fromRGB(255, 150, 50))
        pcall(function()
            local args = {getKickPower(), getKickArg2()}
            game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("rev_KickEvent"):FireServer(unpack(args))
        end)

        if not running then break end

        setStatus("Nunggu mendarat... [" .. currentTarget .. "]", Color3.fromRGB(200, 100, 255))
        local timeout = 30
        local elapsed = 0
        local kicked = false
        while elapsed < timeout and running do
            task.wait(0.1)
            elapsed = elapsed + 0.1
            local r = getRoot()
            if r and r.Position.X < 700 then
                kicked = true
                break
            end
        end

        if not kicked or not running then
            setStatus("Timeout, tendangan gagal. Retry...", Color3.fromRGB(255, 50, 50))
            task.wait(1)
            continue
        end

        if not running then break end

        setStatus("Mendarat! Scan... [" .. currentTarget .. "]", Color3.fromRGB(100, 220, 100))
        local debris = workspace:WaitForChild("Debris")
        local brainrot = nil

        local function findBrainrot()
            local r = getRoot()
            if not r then return nil end
            local closest = nil
            local shortestDist = math.huge
            for _, child in ipairs(debris:GetChildren()) do
                if child:IsA("Model") and child.PrimaryPart and child.PrimaryPart.Name == "Root" then
                    local dist = (child.PrimaryPart.Position - r.Position).Magnitude
                    if dist < shortestDist then
                        shortestDist = dist
                        closest = child
                    end
                end
            end
            if closest and shortestDist < 150 then return closest end
            return nil
        end

        local char4 = player.Character
        local shouldBundir = false

        if char4 then
            local hum4 = char4:FindFirstChild("Humanoid")
            if hum4 then
                task.wait(2)
                setStatus("Balik SafeZone... [" .. currentTarget .. "]", Color3.fromRGB(100, 220, 100))
                local bv = Instance.new("BodyVelocity")
                bv.MaxForce = Vector3.new(1e5, 0, 1e5)
                bv.Parent = char4:FindFirstChild("HumanoidRootPart")

                while running do
                    local r2 = getRoot()
                    if not r2 then break end

                    local found = findBrainrot()
                    if found and not brainrot then
                        brainrot = found
                        local mutVal2 = brainrot:GetAttribute("Mutation") or "None"
                        local basePrice = BASE_PRICE[brainrot.Name] or 0
                        local multiplier = MULTIPLIER[mutVal2] or 1
                        local actualPrice = basePrice * multiplier
                        if not isValidBrainrot(brainrot) then
                            setStatus("Bundir: " .. brainrot.Name .. " [" .. mutVal2 .. "] $" .. math.floor(actualPrice/1000) .. "K/s", Color3.fromRGB(255, 50, 50))
                            shouldBundir = true
                            break
                        end
                        setStatus("Valid! $" .. math.floor(actualPrice/1000) .. "K/s - " .. brainrot.Name, Color3.fromRGB(100, 220, 100))
                    end

                    if brainrot and not brainrot.Parent then break end
                    if (r2.Position - SAFE_POS).Magnitude < 5 then break end

                    local dir = (SAFE_POS - r2.Position).Unit
                    local speed = (hum4 and hum4.WalkSpeed or 16) + getSpeedBoost()
                    bv.Velocity = Vector3.new(dir.X * speed, 0, dir.Z * speed)
                    task.wait(0.1)
                end
                bv:Destroy()
            end
        end

        if shouldBundir then
            task.wait(1)
            bundir()
            setStatus("Bundir, nunggu respawn...", Color3.fromRGB(255, 50, 50))
            repeat task.wait(0.1) until player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
            
            setStatus("Loading inventory...", Color3.fromRGB(255, 180, 50))
            task.wait(1.5)
            continue
        end

        if not brainrot or not running then
            setStatus("Timeout brainrot, retry...", Color3.fromRGB(255, 50, 50))
            task.wait(1)
            continue
        end

        local mutVal = brainrot:GetAttribute("Mutation") or "None"
        local basePrice = BASE_PRICE[brainrot.Name] or 0
        local multiplier = MULTIPLIER[mutVal] or 1
        local actualPrice = basePrice * multiplier
        setStatus("Masukin tas: " .. brainrot.Name .. " $" .. math.floor(actualPrice/1000) .. "K/s", Color3.fromRGB(100, 220, 100))

        local isRemoved = false
        local removedConn = brainrot.AncestryChanged:Connect(function()
            if not brainrot.Parent then isRemoved = true end
        end)

        local char5 = player.Character
        if char5 then
            local hum5 = char5:FindFirstChild("Humanoid")
            if hum5 then
                local bv2 = Instance.new("BodyVelocity")
                bv2.MaxForce = Vector3.new(1e5, 0, 1e5)
                bv2.Parent = char5:FindFirstChild("HumanoidRootPart")

                while not isRemoved and running do
                    if not brainrot.Parent then isRemoved = true break end
                    local r3 = getRoot()
                    if r3 then
                        local dir2 = (SAFE_POS - r3.Position).Unit
                        local speed2 = (hum5 and hum5.WalkSpeed or 16) + getSpeedBoost()
                        bv2.Velocity = Vector3.new(dir2.X * speed2, 0, dir2.Z * speed2)
                    end
                    task.wait(0.1)
                end
                bv2:Destroy()
            end
        end
        removedConn:Disconnect()

        if not running then break end

        setStatus("Brainrot selesai! Langsung kick...", Color3.fromRGB(100, 220, 100))
        task.wait(0.5)
    end

    setStatus("Idle", Color3.fromRGB(200, 200, 200))
    setInfo("", Color3.fromRGB(150, 150, 150))
end

