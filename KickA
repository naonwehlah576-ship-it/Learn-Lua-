local function autoScanIndex()
    pcall(function()
        local playerGui = player:WaitForChild("PlayerGui", 5)
        if not playerGui then return end
        local scrollingFrame = playerGui:FindFirstChild("Frames") and playerGui.Frames:FindFirstChild("Index") and playerGui.Frames.Index:FindFirstChild("Holder") and playerGui.Frames.Index.Holder:FindFirstChild("ScrollingFrame")
        if not scrollingFrame then return end

        local count = 0
        for _, item in ipairs(scrollingFrame:GetChildren()) do
            local cpsLabel = item:FindFirstChild("CPSLabel")
            if cpsLabel and cpsLabel:IsA("TextLabel") then
                local numStr, suffix = string.match(cpsLabel.Text, "%$([%d%.]+)([KMBkmb]?)/s")
                if not numStr then numStr, suffix = string.match(cpsLabel.Text, "([%d%.]+)([KMBkmb]?)") end
                if numStr then
                    local val = tonumber(numStr)
                    if val then
                        suffix = string.upper(suffix or "")
                        if suffix == "K" then val = val * 1000
                        elseif suffix == "M" then val = val * 1000000
                        elseif suffix == "B" then val = val * 1000000000 end
                        BASE_PRICE[item.Name] = math.floor(val)
                        count = count + 1
                    end
                end
            end
        end
    end)
end

