local function autoSetBaconKickPower()
    if not isBaconExpired() then
        KickPowerBox.Text = "1"
        KickArg2Box.Text = tostring(getMaxKickPower())
        setInfo("🥓 Bacon: Sedang Aktif!", Color3.fromRGB(255, 180, 50))
        return false
    end
    
    if hasEnoughBaconStok() then
        KickPowerBox.Text = "1"
        KickArg2Box.Text = tostring(getMaxKickPower())
        setInfo("🥓 Bacon: Stok penuh, aktifasi!", Color3.fromRGB(255, 220, 50))
        return tryActivateBacon()
    end
    
    local target = getBaconStokTarget()
    
    -- CARI JUMLAH STOK PALING SEDIKIT DARI SEMUA TUMBAL
    local lowestCount = math.huge
    for _, name in ipairs(BACON_REQUIRED_LIST) do
        local count = countInBackpack(name)
        if count < lowestCount then
            lowestCount = count
        end
    end

    local selectedPower = nil
    local groupedNames = {}

    for _, name in ipairs(BACON_REQUIRED_LIST) do
        local count = countInBackpack(name)
        
        -- HANYA FOKUS MENGUMPULKAN ITEM YANG JUMLAHNYA PALING SEDIKIT (Round-Robin)
        if count == lowestCount and count < target then
            local targetPower = BACON_KICK_POWER[name]
            if not targetPower or targetPower == 0 then targetPower = getMaxKickPower() end
            
            if not selectedPower then
                selectedPower = targetPower
                table.insert(groupedNames, {n = name, c = count})
            elseif selectedPower == targetPower then
                table.insert(groupedNames, {n = name, c = count})
            end
        end
    end

    if selectedPower then
        KickArg2Box.Text = tostring(selectedPower)
        KickPowerBox.Text = "1"
        
        local strList = {}
        for _, item in ipairs(groupedNames) do
            local shortName = string.split(item.n, " ")[1]
            table.insert(strList, shortName .. " " .. item.c .. "/" .. target)
        end
        
        setInfo("🥓 Cari: " .. table.concat(strList, " & "), Color3.fromRGB(255, 150, 50))
        return false
    end

    setInfo("🥓 Bacon: Idle", Color3.fromRGB(150, 150, 150))
    return false
end

