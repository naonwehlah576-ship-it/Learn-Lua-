local CONFIG_FILE = "BrainrotConfigs.json"
local isSaveMode = false

local function getConfigs()
    local ok, data = pcall(readfile, CONFIG_FILE)
    if not ok or not data or data == "" then return {} end
    local ok2, parsed = pcall(game:GetService("HttpService").JSONDecode, game:GetService("HttpService"), data)
    if not ok2 then return {} end
    return parsed
end

local function saveConfigs(configs)
    local ok, data = pcall(game:GetService("HttpService").JSONEncode, game:GetService("HttpService"), configs)
    if ok then pcall(writefile, CONFIG_FILE, data) end
end

