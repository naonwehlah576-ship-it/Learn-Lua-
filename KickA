-- ================== HELPER FUNCTIONS (early) ==================
local function parseKickPower(text)
    local num = string.match(text, "([%d%.]+)([KMB]?)")
    if not num then return 1000000000 end
    local val = tonumber(num) or 0
    local suffix = string.match(text, "%d[%.%d]*([KMBkmb])")
    if suffix then
        suffix = string.upper(suffix)
        if suffix == "K" then val = val * 1000
        elseif suffix == "M" then val = val * 1000000
        elseif suffix == "B" then val = val * 1000000000
        end
    end
    return val
end

local function getMaxKickPower()
    local ok, label = pcall(function()
        return game:GetService("Players").LocalPlayer.PlayerGui.HUD.BottomLeft.KickLevel.TextLabel
    end)
    if not ok or not label then return 1000000000 end
    return parseKickPower(label.Text)
end

-- FUNGSI INI DIPINDAH KE ATAS BIAR BISA DIBACA OLEH BACON DAN UFO
local function hasInBackpack(name)
    -- cek backpack
    for _, item in ipairs(player.Backpack:GetChildren()) do
        if item.Name == name then return true end
    end
    -- cek character
    if player.Character then
        for _, item in ipairs(player.Character:GetChildren()) do
            if item.Name == name then return true end
        end
    end
    return false
end

