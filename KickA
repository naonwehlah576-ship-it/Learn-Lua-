    -- UFO tidak aktif, kalau semua brainrot ada -> aktifin UFO
    if hasAllUFOBrainrots() then
        KickPowerBox.Text = "1"
        KickArg2Box.Text = "3800000000"
        tryActivateUFO()
        return
    end

    -- cari brainrot pertama yang belum ada, set kick power nya
    for _, name in ipairs(UFO_REQUIRED) do
        if not hasInBackpack(name) then
            local targetPower = UFO_KICK_POWER[name]
if not targetPower or targetPower == 0 then targetPower = getMaxKickPower() end
            KickArg2Box.Text = tostring(targetPower)
            KickPowerBox.Text = "1"
            setStatus("Auto power: cari " .. name, Color3.fromRGB(255, 200, 50))
            return
        end
    end
end

