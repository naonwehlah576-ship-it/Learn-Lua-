            end)
        end
    end
end)

-- ================== MAIN LOOP ==================
local function runLoop()
    while running do
        local char0 = player.Character
        local hum0 = char0 and char0:FindFirstChild("Humanoid")
        if not char0 or not hum0 or hum0.Health <= 0 then
            setStatus("Nunggu respawn...", Color3.fromRGB(255, 100, 50))
            repeat task.wait(0.1) until player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
            setStatus("Loading inventory...", Color3.fromRGB(255, 180, 50))
            task.wait(0.5)
        end

        local isUfoActive = not isUFOExpired()
        local isBaconActive = not isBaconExpired()
        local isHeavenlyActive = not isHeavenlyExpired()
        local justActivated = false

        if (isUfoActive or isBaconActive or isHeavenlyActive) and (autoUFORunning or autoBaconRunning or autoHeavenlyRunning) then
            KickPowerBox.Text = "1"
            KickArg2Box.Text = tostring(getMaxKickPower())
            setInfo("🚨 EVENT AKTIF! FORCE MAX", Color3.fromRGB(255, 50, 50))
        else
            if autoHeavenlyRunning and not hasAllHeavenlyBrainrots() then
                justActivated = autoSetHeavenlyKickPower() or false
            elseif autoBaconRunning and not hasEnoughBaconStok() then
                justActivated = autoSetBaconKickPower() or false
            elseif autoUFORunning and not hasAllUFOBrainrots() then
                justActivated = autoSetKickPower() or false
            elseif autoHeavenlyRunning and hasAllHeavenlyBrainrots() then
                justActivated = autoSetHeavenlyKickPower() or false
            elseif autoBaconRunning and hasEnoughBaconStok() then
                justActivated = autoSetBaconKickPower() or false 
            elseif autoUFORunning and hasAllUFOBrainrots() then
                justActivated = autoSetKickPower() or false
            end
        end
        
        if justActivated then continue end

        setStatus("TP ke kick spot...", Color3.fromRGB(100, 180, 255))
        local root = getRoot()
        if not root then task.wait(1) continue end
        pcall(function() root.CFrame = CFrame.new(KICK_POS) end)
        task.wait(0.5)

        if not running then break end

        setStatus("Nge-kick...", Color3.fromRGB(255, 150, 50))
        pcall(function()
            game:GetService("ReplicatedStorage"):WaitForChild("Shared"):WaitForChild("Packages"):WaitForChild("Network"):WaitForChild("rev_KickEvent"):FireServer(getKickPower(), getKickArg2())
        end)

        if not running then break end

        setStatus("Nunggu kena kick...", Color3.fromRGB(200, 100, 255))
        local elapsed, kicked = 0, false
        while elapsed < 30 and running do
            task.wait(0.1); elapsed = elapsed + 0.1
            local r = getRoot()
            if r and r.Position.X < 690 then kicked = true break end
        end

        if not kicked or not running then
            setStatus("Timeout/stop, retry...", Color3.fromRGB(255, 50, 50))
            task.wait(1)
            continue
        end

        if not running then break end

        setStatus("Mendarat! Nunggu brainrot spawn...", Color3.fromRGB(100, 220, 100))
        local brainrot = nil
        
        local function findNearbyBrainrots()
            local r = getRoot(); if not r then return {} end
            local foundList = {}
            for _, outerModel in ipairs(workspace:WaitForChild("Debris"):GetChildren()) do
                if outerModel:IsA("Model") then
                    for _, innerModel in ipairs(outerModel:GetChildren()) do
                        if innerModel:IsA("Model") and innerModel.PrimaryPart and innerModel.PrimaryPart.Name == "Root" then
                            local dist = (innerModel.PrimaryPart.Position - r.Position).Magnitude
                            if dist <= 40 then 
                                table.insert(foundList, innerModel)
                            end
                        end
                    end
                end
            end
            return foundList
        end

        local char4 = player.Character
        local shouldBundir = false

        if char4 then
            local hum4 = char4:FindFirstChild("Humanoid")
            if hum4 then
                task.wait(2)
                setStatus("Jalan ke safe zone + scanning...", Color3.fromRGB(100, 220, 100))
                local bv = Instance.new("BodyVelocity")
                bv.MaxForce = Vector3.new(1e5, 0, 1e5)
                bv.Parent = char4:FindFirstChild("HumanoidRootPart")

                while running do
                    local r2 = getRoot(); if not r2 then break end
                    
                    local foundList = findNearbyBrainrots()
                    
                    if #foundList > 0 and not brainrot then
                        local hasValid = false
                        local bestTarget = nil
                        local highestVal = -1
                        local sampleTrash = foundList[1]
                        
                        for _, b in ipairs(foundList) do
                            if isValidBrainrot(b) then
                                hasValid = true
                                local mutV = b:GetAttribute("Mutation") or "None"
                                local val = (BASE_PRICE[b.Name] or 0) * (MULTIPLIER[mutV] or 1)
                                
                                if val > highestVal then
                                    highestVal = val
                                    bestTarget = b
                                end
                            end
                        end
                        
                        if hasValid then
                            brainrot = bestTarget
                            local mutVal2 = brainrot:GetAttribute("Mutation") or "None"
                            local actualPrice = (BASE_PRICE[brainrot.Name] or 0) * (MULTIPLIER[mutVal2] or 1)
                            setStatus("Valid! $" .. math.floor(actualPrice/1000) .. "K/s - " .. brainrot.Name, Color3.fromRGB(100, 220, 100))
                        else
                            local mutValTrash = sampleTrash:GetAttribute("Mutation") or "None"
                            local actPriceTrash = (BASE_PRICE[sampleTrash.Name] or 0) * (MULTIPLIER[mutValTrash] or 1)
                            setStatus("Bundir: " .. sampleTrash.Name .. " [" .. mutValTrash .. "] $" .. math.floor(actPriceTrash/1000) .. "K/s", Color3.fromRGB(255, 50, 50))
                            shouldBundir = true
                            break
                        end
                    end

                    if brainrot and not brainrot.Parent then break end
                    if (r2.Position - SAFE_POS).Magnitude < 5 then break end

                    local dir = (SAFE_POS - r2.Position).Unit
                    local speed = (hum4 and hum4.WalkSpeed or 16) + getSpeedBoost()
                    bv.Velocity = Vector3.new(dir.X * speed, 0, dir.Z * speed)
                    task.wait(0.1)
                end
                bv:Destroy()
            end
        end

        if shouldBundir then
            task.wait(1); bundir()
            setStatus("Bundir, nunggu respawn...", Color3.fromRGB(255, 50, 50))
            repeat task.wait(0.1) until player.Character and player.Character:FindFirstChild("Humanoid") and player.Character.Humanoid.Health > 0
            setStatus("Loading inventory...", Color3.fromRGB(255, 180, 50)); task.wait(1.5)
            continue
        end

        if not brainrot or not running then
            setStatus("Timeout brainrot, retry...", Color3.fromRGB(255, 50, 50)); task.wait(1)
            continue
        end

        local mutVal = brainrot:GetAttribute("Mutation") or "None"
        local actualPrice = (BASE_PRICE[brainrot.Name] or 0) * (MULTIPLIER[mutVal] or 1)
        setStatus("Nunggu removed: " .. brainrot.Name .. " $" .. math.floor(actualPrice/1000) .. "K/s", Color3.fromRGB(100, 220, 100))

        local isRemoved = false
        local removedConn = brainrot.AncestryChanged:Connect(function() if not brainrot.Parent then isRemoved = true end end)

        local char5 = player.Character
        if char5 then
            local hum5 = char5:FindFirstChild("Humanoid")
            if hum5 then
                local bv2 = Instance.new("BodyVelocity")
                bv2.MaxForce = Vector3.new(1e5, 0, 1e5); bv2.Parent = char5:FindFirstChild("HumanoidRootPart")
                while not isRemoved and running do
                    if not brainrot.Parent then isRemoved = true break end
                    local r3 = getRoot()
                    if r3 then
                        local dir2 = (SAFE_POS - r3.Position).Unit
                        local speed2 = (hum5 and hum5.WalkSpeed or 16) + getSpeedBoost()
                        bv2.Velocity = Vector3.new(dir2.X * speed2, 0, dir2.Z * speed2)
                    end
                    task.wait(0.1)
                end
                bv2:Destroy()
            end
        end
        removedConn:Disconnect()

        if not running then break end
        setStatus("Brainrot selesai! Jeda 2 dtk...", Color3.fromRGB(100, 220, 100))
        task.wait(2)
    end
    setStatus("Idle", Color3.fromRGB(200, 200, 200))
    setInfo("", Color3.fromRGB(150, 150, 150))
end

