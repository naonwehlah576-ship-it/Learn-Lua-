local function getMinHarga()
    local val = tonumber(MinBox.Text)
    if not val or val <= 0 then return 4 end
    return val * 1000000
end

local function getKickPower()
    local val = tonumber(KickPowerBox.Text)
    if not val or val <= 0 then return 1 end
    return val
end

local function getKickArg2()
    local val = tonumber(KickArg2Box.Text)
    if not val or val <= 0 then return 0 end
    return val / getMaxKickPower()
end

