local function applySettings(cfg)
    if not cfg then return end
    pcall(function() if cfg.minHarga then MinBox.Text = cfg.minHarga end end)
    pcall(function() if cfg.flySpeed then FlySpeedBox.Text = cfg.flySpeed end end)
    pcall(function() if cfg.kickPower then KickPowerBox.Text = cfg.kickPower end end)
    pcall(function() if cfg.kickArg2 then KickArg2Box.Text = cfg.kickArg2 end end)
    pcall(function() if cfg.minFav then MinFavBox.Text = cfg.minFav end end)
    pcall(function() if cfg.speedBoost then SpeedBoostBox.Text = cfg.speedBoost end end)
    
    if cfg.favAutoRunning ~= nil then
        favAutoRunning = cfg.favAutoRunning
        if favAutoRunning then
            FavToggleBtn.Text = "⭐ Auto Fav: ON"
            FavToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 200, 0)
            FavToggleBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        else
            FavToggleBtn.Text = "⭐ Auto Fav: OFF"
            FavToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            FavToggleBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end
    
    if cfg.autoUFORunning ~= nil then
        autoUFORunning = cfg.autoUFORunning
        if autoUFORunning then
            UFOToggleBtn.Text = "🛸 Auto UFO: ON"
            UFOToggleBtn.BackgroundColor3 = Color3.fromRGB(100, 200, 255)
            UFOToggleBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        else
            UFOToggleBtn.Text = "🛸 Auto UFO: OFF"
            UFOToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            UFOToggleBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end
    
    if cfg.autoBaconRunning ~= nil then
        autoBaconRunning = cfg.autoBaconRunning
        if autoBaconRunning then
            BaconToggleBtn.Text = "🥓 Auto Bacon: ON"
            BaconToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 30)
            BaconToggleBtn.TextColor3 = Color3.fromRGB(20, 20, 20)
        else
            BaconToggleBtn.Text = "🥓 Auto Bacon: OFF"
            BaconToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
            BaconToggleBtn.TextColor3 = Color3.fromRGB(150, 150, 150)
        end
    end
    
    if cfg.bacon then
        for k, v in pairs(cfg.bacon) do baconEnabled[k] = v end
        for _, fn in ipairs(updateBaconUI) do fn() end
    end
    if cfg.ufo then
        for k, v in pairs(cfg.ufo) do ufoEnabled[k] = v end
        for _, fn in ipairs(updateUFOUI) do fn() end
    end
end

local function refreshConfigList(mode)
    for _, child in ipairs(ScrollFrame:GetChildren()) do
        if child:IsA("TextButton") or child:IsA("Frame") then child:Destroy() end
    end
    local configs = getConfigs()
    local count = 0
    for name, _ in pairs(configs) do
        if name == "__last" then continue end
        count = count + 1
        local row = Instance.new("Frame")
        row.Size = UDim2.new(1, 0, 0, 28)
        row.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        row.BorderSizePixel = 0
        row.ZIndex = 10
        row.Parent = ScrollFrame
        Instance.new("UICorner", row).CornerRadius = UDim.new(0, 4)

        local nameBtn = Instance.new("TextButton")
        nameBtn.Size = UDim2.new(1, -32, 1, 0)
        nameBtn.Position = UDim2.new(0, 4, 0, 0)
        nameBtn.BackgroundTransparency = 1
        nameBtn.Text = name
        nameBtn.TextColor3 = Color3.fromRGB(220, 220, 220)
        nameBtn.TextSize = 10
        nameBtn.Font = Enum.Font.Gotham
        nameBtn.TextXAlignment = Enum.TextXAlignment.Left
        nameBtn.ZIndex = 11
        nameBtn.Parent = row

        local delBtn = Instance.new("TextButton")
        delBtn.Size = UDim2.new(0, 24, 0, 24)
        delBtn.Position = UDim2.new(1, -28, 0, 2)
        delBtn.BackgroundColor3 = Color3.fromRGB(180, 40, 40)
        delBtn.Text = "🗑"
        delBtn.TextSize = 10
        delBtn.Font = Enum.Font.GothamBold
        delBtn.ZIndex = 11
        delBtn.Parent = row
        Instance.new("UICorner", delBtn).CornerRadius = UDim.new(0, 4)

        local capturedName = name
        nameBtn.MouseButton1Click:Connect(function()
            if mode == "load" then
                local cfgs = getConfigs()
                if cfgs[capturedName] then
                    applySettings(cfgs[capturedName])
                    local meta = getConfigs()
                    meta["__last"] = capturedName
                    saveConfigs(meta)
                    ConfigTitle.Text = "Loaded: " .. capturedName
                    task.wait(1)
                    ConfigFrame.Visible = false
                end
            end
        end)

        delBtn.MouseButton1Click:Connect(function()
            local cfgs = getConfigs()
            cfgs[capturedName] = nil
            saveConfigs(cfgs)
            refreshConfigList(mode)
        end)
    end

    if count == 0 then
        local empty = Instance.new("TextLabel")
        empty.Size = UDim2.new(1, 0, 0, 28)
        empty.BackgroundTransparency = 1
        empty.Text = "Belum ada config"
        empty.TextColor3 = Color3.fromRGB(150, 150, 150)
        empty.TextSize = 10
        empty.Font = Enum.Font.Gotham
        empty.ZIndex = 10
        empty.Parent = ScrollFrame
    end
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, count * 32)
end

